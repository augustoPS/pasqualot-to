---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const albums = await getCollection('albums');
  return albums.map((album) => ({
    params: { slug: album.id },
    props: { album },
  }));
}

const { album } = Astro.props;
const { title, date, location, description, cover, photos, previewCount } = album.data;
const isProtected = album.data.protected;
const year = new Date(date).getFullYear();
const ogImage = `/photos/${album.id}/${cover}`;

const previewPhotos = isProtected ? photos.slice(0, previewCount) : photos;
const lockedCount = isProtected ? Math.max(0, photos.length - previewCount) : 0;

// Thumbnail URL helper — protected photos go through the auth proxy, public through the thumbs route
function thumbUrl(file: string) {
  return isProtected
    ? `/api/photos/${album.id}/${file}?w=300`
    : `/api/thumbs/${album.id}/${file}?w=300`;
}
function fullUrl(file: string) {
  return isProtected ? `/api/photos/${album.id}/${file}` : `/photos/${album.id}/${file}`;
}
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-5xl mx-auto px-6 py-12">

    <!-- Album header -->
    <div class="mb-8">
      <h1 class="text-2xl font-medium text-[var(--color-accent)]">{title}</h1>
      <p class="text-sm text-[var(--color-muted)] mt-1">
        {location ? `${location}, ` : ''}{year}
      </p>
      {description && (
        <p class="text-sm text-[var(--color-text)] mt-3 max-w-xl">{description}</p>
      )}
    </div>

    <!-- Centered preview -->
    <div class="flex flex-col items-center gap-6">
      <button
        id="preview-btn"
        class="w-full max-w-2xl cursor-zoom-in block"
        aria-label="View photo fullscreen"
        onclick="openLightbox()"
      >
        <img
          id="preview-img"
          src={fullUrl(previewPhotos[0].file)}
          alt={previewPhotos[0].alt}
          class="w-full object-contain max-h-[70vh]"
        />
      </button>

      <!-- Thumbnail strip -->
      <div class="w-full flex flex-col items-center gap-3">
        <div id="thumb-strip" class="flex gap-2 justify-center flex-wrap">
          {previewPhotos.map((photo, i) => (
            <button
              class:list={[
                'thumb flex-shrink-0 w-16 h-16 overflow-hidden transition-opacity duration-150',
                i === 0 ? 'ring-1 ring-[var(--color-accent)] opacity-100' : 'opacity-40 hover:opacity-80'
              ]}
              data-src={fullUrl(photo.file)}
              data-alt={photo.alt}
              data-index={i}
              aria-label={`View ${photo.alt}`}
            >
              <img src={thumbUrl(photo.file)} alt={photo.alt} class="w-full h-full object-cover" loading="lazy" />
            </button>
          ))}
          <!-- Locked thumbs injected here after auth -->
        </div>

        <button
          id="load-more-btn"
          class="text-xs text-[var(--color-muted)] hover:text-[var(--color-text)] border border-[var(--color-border)] hover:border-[var(--color-muted)] px-4 py-1.5 transition-colors"
          style="display:none"
          onclick="loadMoreThumbs()"
        >
          Load more
        </button>
        <p id="load-more-count" class="text-xs text-[var(--color-muted)]" style="display:none"></p>
      </div>
    </div>

    <!-- Password gate -->
    {isProtected && lockedCount > 0 && (
      <div id="password-gate" class="mt-10 border border-[var(--color-border)] p-8 text-center">
        <p class="text-sm text-[var(--color-muted)] mb-1">
          {lockedCount} more photo{lockedCount !== 1 ? 's' : ''}
        </p>
        <p class="text-base text-[var(--color-text)] mb-6">Enter the password to view the full album</p>
        <form id="password-form" class="flex flex-col sm:flex-row gap-3 justify-center max-w-sm mx-auto">
          <input
            type="password"
            id="password-input"
            placeholder="Password"
            class="flex-1 bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text)] px-4 py-2 text-sm outline-none focus:border-[var(--color-muted)] placeholder:text-[var(--color-muted)]"
            autocomplete="current-password"
          />
          <button
            type="submit"
            class="px-6 py-2 text-sm bg-white text-black hover:bg-[var(--color-text)] transition-colors"
          >
            Unlock
          </button>
        </form>
        <p id="password-error" class="text-xs text-red-400 mt-3 hidden">Incorrect password.</p>
      </div>
    )}
  </div>

  <!-- Lightbox -->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95"
    role="dialog"
    aria-modal="true"
    aria-label="Photo lightbox"
  >
    <button id="lightbox-close" class="absolute top-5 right-6 text-white/50 hover:text-white text-2xl leading-none transition-colors" aria-label="Close">&#x2715;</button>
    <button id="lightbox-prev" class="absolute left-4 text-white/40 hover:text-white text-3xl leading-none transition-colors px-2 py-4" aria-label="Previous photo">&#x2039;</button>
    <img id="lightbox-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain select-none" />
    <button id="lightbox-next" class="absolute right-4 text-white/40 hover:text-white text-3xl leading-none transition-colors px-2 py-4" aria-label="Next photo">&#x203A;</button>
  </div>
</BaseLayout>

<script define:vars={{ isProtected, albumId: album.id, previewCount, isProtectedAlbum: isProtected }}>
  const THUMB_PAGE = 20;
  let allPhotos = []; // all photos available (preview + unlocked)
  let loadedThumbCount = 0;
  let activeIndex = 0;

  const previewImg  = document.getElementById('preview-img');
  const strip       = document.getElementById('thumb-strip');
  const loadMoreBtn = document.getElementById('load-more-btn');
  const loadMoreCount = document.getElementById('load-more-count');

  // Collect initially rendered preview photos
  document.querySelectorAll('.thumb').forEach(btn => {
    allPhotos.push({ src: btn.dataset.src, alt: btn.dataset.alt, thumbSrc: btn.querySelector('img')?.src });
  });
  loadedThumbCount = allPhotos.length;

  function selectPhoto(index) {
    activeIndex = index;
    const photo = allPhotos[index];
    previewImg.src = photo.src;
    previewImg.alt = photo.alt;
    document.querySelectorAll('.thumb').forEach(btn => {
      const active = Number(btn.dataset.index) === index;
      btn.classList.toggle('ring-1', active);
      btn.classList.toggle('ring-[var(--color-accent)]', active);
      btn.classList.toggle('opacity-100', active);
      btn.classList.toggle('opacity-40', !active);
    });
  }

  function addThumb(photo, index) {
    const btn = document.createElement('button');
    btn.className = 'thumb flex-shrink-0 w-16 h-16 overflow-hidden transition-opacity duration-150 opacity-40 hover:opacity-80';
    btn.dataset.src   = photo.src;
    btn.dataset.alt   = photo.alt;
    btn.dataset.index = String(index);
    btn.setAttribute('aria-label', `View ${photo.alt}`);
    const img = document.createElement('img');
    img.src = photo.thumbSrc ?? photo.src;
    img.alt = photo.alt;
    img.className = 'w-full h-full object-cover';
    img.loading = 'lazy';
    btn.appendChild(img);
    btn.addEventListener('click', () => selectPhoto(index));
    strip.appendChild(btn);
  }

  function updateLoadMore() {
    const remaining = allPhotos.length - loadedThumbCount;
    if (remaining > 0) {
      loadMoreBtn.style.display = 'block';
      loadMoreCount.style.display = 'block';
      loadMoreCount.textContent = `${loadedThumbCount} of ${allPhotos.length} photos`;
    } else {
      loadMoreBtn.style.display = 'none';
      loadMoreCount.style.display = 'none';
    }
  }

  window.loadMoreThumbs = function() {
    const batch = allPhotos.slice(loadedThumbCount, loadedThumbCount + THUMB_PAGE);
    batch.forEach((photo, i) => addThumb(photo, loadedThumbCount + i));
    loadedThumbCount += batch.length;
    updateLoadMore();
  };

  // Bind existing thumbs
  document.querySelectorAll('.thumb').forEach(btn => {
    btn.addEventListener('click', () => selectPhoto(Number(btn.dataset.index)));
  });

  // Lightbox
  const lightbox    = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');

  window.openLightbox = function() {
    lightboxImg.src = allPhotos[activeIndex].src;
    lightboxImg.alt = allPhotos[activeIndex].alt;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function lightboxPrev() {
    activeIndex = (activeIndex - 1 + allPhotos.length) % allPhotos.length;
    lightboxImg.src = allPhotos[activeIndex].src;
    lightboxImg.alt = allPhotos[activeIndex].alt;
    selectPhoto(activeIndex);
  }

  function lightboxNext() {
    activeIndex = (activeIndex + 1) % allPhotos.length;
    lightboxImg.src = allPhotos[activeIndex].src;
    lightboxImg.alt = allPhotos[activeIndex].alt;
    selectPhoto(activeIndex);
  }

  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev').addEventListener('click', lightboxPrev);
  document.getElementById('lightbox-next').addEventListener('click', lightboxNext);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') lightboxPrev();
    if (e.key === 'ArrowRight') lightboxNext();
  });

  // Password gate
  if (isProtected) {
    const storageKey = `unlocked:${albumId}`;

    async function fetchAndUnlock() {
      const res = await fetch(`/api/albums/${albumId}/photos`);
      if (!res.ok) return false;
      const { photos: locked } = await res.json();
      locked.forEach(p => allPhotos.push({
        src: p.src,
        thumbSrc: `${p.src}?w=300`,
        alt: p.alt,
      }));
      updateLoadMore();
      return true;
    }

    async function unlock() {
      const ok = await fetchAndUnlock();
      if (!ok) return;
      document.getElementById('password-gate').classList.add('hidden');
    }

    if (sessionStorage.getItem(storageKey) === 'true') unlock();

    document.getElementById('password-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = document.getElementById('password-input').value;
      const res = await fetch('/api/auth/album', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ album: albumId, password: input }),
      });
      if (res.ok) {
        sessionStorage.setItem(storageKey, 'true');
        unlock();
      } else {
        const err = document.getElementById('password-error');
        err.classList.remove('hidden');
        document.getElementById('password-input').value = '';
      }
    });
  }
</script>
