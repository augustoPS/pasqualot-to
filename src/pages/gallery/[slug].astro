---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const albums = await getCollection('albums');
  return albums.map((album) => ({
    params: { slug: album.id },
    props: { album },
  }));
}

const { album } = Astro.props;
const { title, date, location, description, cover, photos, previewCount } = album.data;
const isProtected = album.data.protected;
const year = new Date(date).getFullYear();
const ogImage = `/photos/${album.id}/${cover}`;

const previewPhotos = isProtected ? photos.slice(0, previewCount) : photos;
const lockedCount = isProtected ? Math.max(0, photos.length - previewCount) : 0;

// Thumbnail URL helper
// Preview photos of protected albums are stored in public/photos/ — serve them directly.
// Locked photos go through the auth proxy. Public albums use the thumbs route.
const previewFiles = new Set(previewPhotos.map(p => p.file));

function thumbUrl(file: string) {
  if (!isProtected || previewFiles.has(file)) {
    const jpg = file.replace(/\.[^.]+$/, '.jpg');
    return `/photos/${album.id}/thumbs/${jpg}`;
  }
  return `/api/photos/${album.id}/${file}?w=300`;
}
function fullUrl(file: string) {
  if (!isProtected || previewFiles.has(file)) return `/photos/${album.id}/${file}`;
  return `/api/photos/${album.id}/${file}`;
}
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-5xl mx-auto px-6">

    <!-- Sticky preview window: header + photo stay fixed while thumbs scroll below -->
    <div class="sticky top-0 z-10 bg-[var(--color-bg)] pt-8 pb-4 border-b border-[var(--color-border)]">

      <!-- Album header -->
      <div class="mb-4">
        <a href="/" class="text-xs text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors inline-block mb-2">← Gallery</a>
        <h1 class="text-2xl font-medium text-[var(--color-accent)]">{title}</h1>
        <p class="text-sm text-[var(--color-muted)] mt-1">
          {location ? `${location}, ` : ''}{year}
        </p>
        {description && (
          <p class="text-sm text-[var(--color-text)] mt-2 max-w-xl">{description}</p>
        )}
      </div>

      <!-- Preview image with mobile prev/next arrows -->
      <div class="relative w-full max-w-2xl mx-auto">
        <button
          id="preview-prev"
          class="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-11 h-11 flex items-center justify-center text-white/60 hover:text-white bg-black/30 hover:bg-black/60 transition-colors sm:hidden"
          aria-label="Previous photo"
          onclick="previewNavigate(-1)"
        >&#x2039;</button>

        <button
          id="preview-btn"
          class="w-full cursor-zoom-in block"
          aria-label="View photo fullscreen"
          onclick="openLightbox()"
        >
          <img
            id="preview-img"
            src={fullUrl(previewPhotos[0].file)}
            alt={previewPhotos[0].alt}
            class="w-full object-contain max-h-[45vh] sm:max-h-[70vh] transition-opacity duration-200"
          />
        </button>

        <button
          id="preview-next"
          class="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-11 h-11 flex items-center justify-center text-white/60 hover:text-white bg-black/30 hover:bg-black/60 transition-colors sm:hidden"
          aria-label="Next photo"
          onclick="previewNavigate(1)"
        >&#x203A;</button>
      </div>
    </div>

    <!-- Thumbnail strip -->
    <div class="pt-6 pb-8 flex flex-col items-center gap-3">
      <div id="thumb-strip" class="flex gap-2 flex-nowrap overflow-x-auto w-full sm:flex-wrap sm:justify-center snap-x snap-mandatory">
        {previewPhotos.map((photo, i) => (
          <button
            class:list={[
              'thumb flex-shrink-0 w-16 h-16 overflow-hidden transition-opacity duration-150 snap-start',
              i === 0 ? 'ring-1 ring-[var(--color-accent)] opacity-100' : 'opacity-40 hover:opacity-80'
            ]}
            data-src={fullUrl(photo.file)}
            data-alt={photo.alt}
            data-index={i}
            aria-label={`View ${photo.alt}`}
          >
            <img src={thumbUrl(photo.file)} alt={photo.alt} class="w-full h-full object-cover" loading="lazy" />
          </button>
        ))}
        <!-- Locked thumbs injected here after auth -->
      </div>
      <p id="photo-count" class="text-xs text-[var(--color-muted)]"></p>
    </div>
  </div>

  <!-- Password gate: fixed overlay, keeps page scroll-free -->
  {isProtected && lockedCount > 0 && (
    <div
      id="password-gate"
      class="fixed inset-0 z-40 flex items-center justify-center bg-black/70 backdrop-blur-sm transition-opacity duration-200"
      role="dialog"
      aria-modal="true"
      aria-label="Album password"
    >
      <div class="bg-[var(--color-bg)] border border-[var(--color-border)] p-8 w-full max-w-sm mx-4 text-center">
        <p class="text-sm text-[var(--color-muted)] mb-1">
          {lockedCount} more photo{lockedCount !== 1 ? 's' : ''}
        </p>
        <p class="text-base text-[var(--color-text)] mb-6">Enter the password to view the full album</p>
        <form id="password-form" class="flex flex-col sm:flex-row gap-3 justify-center">
          <input
            type="password"
            id="password-input"
            placeholder="Password"
            class="flex-1 bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text)] px-4 py-2 text-sm outline-none focus:border-[var(--color-muted)] placeholder:text-[var(--color-muted)]"
            autocomplete="current-password"
            autofocus
          />
          <button
            id="unlock-btn"
            type="submit"
            class="px-6 py-2 text-sm bg-white text-black hover:bg-[var(--color-text)] transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Unlock
          </button>
        </form>
        <p id="password-error" class="text-xs text-red-400 mt-3 hidden">Incorrect password.</p>
      </div>
    </div>
  )}

  <!-- Lightbox -->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95"
    role="dialog"
    aria-modal="true"
    aria-label="Photo lightbox"
  >
    <button
      id="lightbox-close"
      class="absolute top-5 right-6 text-white/50 hover:text-white text-2xl leading-none transition-colors"
      aria-label="Close"
    >&#x2715;</button>

    <!-- ↑ Expanded tap targets per UX spec 2.3: px-5 py-10 (was px-2 py-4, ~24×56px → ~56×88px) -->
    <button
      id="lightbox-prev"
      class="absolute left-4 text-white/40 hover:text-white text-3xl leading-none transition-colors px-5 py-10"
      aria-label="Previous photo"
    >&#x2039;</button>

    <div class="relative flex items-center justify-center">
      <!-- Loading indicator: visible while lightbox image is loading (spec 2.2) -->
      <span
        id="lightbox-loader"
        class="absolute text-white/30 text-xs tracking-widest animate-pulse select-none hidden"
      >loading</span>
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="max-h-[90vh] max-w-[90vw] object-contain select-none opacity-0 transition-opacity duration-300"
      />
    </div>

    <button
      id="lightbox-next"
      class="absolute right-4 text-white/40 hover:text-white text-3xl leading-none transition-colors px-5 py-10"
      aria-label="Next photo"
    >&#x203A;</button>

    <p id="lightbox-counter" class="absolute bottom-5 left-0 right-0 text-center text-xs text-white/40 select-none"></p>
  </div>
</BaseLayout>

<style>
  /* Hide scrollbar on thumb strip — scrollable but clean */
  #thumb-strip { scrollbar-width: none; }
  #thumb-strip::-webkit-scrollbar { display: none; }
</style>

<script define:vars={{ isProtected, albumId: album.id, previewCount, isProtectedAlbum: isProtected }}>
  let allPhotos = []; // all photos available (preview + unlocked)
  let activeIndex = 0;

  const previewImg  = document.getElementById('preview-img');
  const strip       = document.getElementById('thumb-strip');
  const photoCount  = document.getElementById('photo-count');
  const previewPrev = document.getElementById('preview-prev');
  const previewNext = document.getElementById('preview-next');

  // Show loading state for the initial preview image if it hasn't loaded yet
  if (!previewImg.complete) {
    previewImg.classList.add('opacity-50');
    previewImg.addEventListener('load', () => previewImg.classList.remove('opacity-50'), { once: true });
  }

  // Collect initially rendered preview photos
  document.querySelectorAll('.thumb').forEach(btn => {
    allPhotos.push({ src: btn.dataset.src, alt: btn.dataset.alt, thumbSrc: btn.querySelector('img')?.src });
  });
  updatePhotoCount();
  updatePreviewArrows();

  // ─── BLOCKER 2.1: Preview image loading opacity ───────────────────────────
  // When a thumbnail is clicked and selectPhoto() runs, we immediately set
  // opacity-50 on #preview-img (within the same tick) so the user sees visible
  // feedback while the new full-res image is fetching. The opacity clears the
  // moment the browser fires the load event. If the image was already cached,
  // the flash is imperceptible. onload is assigned BEFORE src so it fires even
  // when the image loads synchronously from cache.
  function selectPhoto(index) {
    activeIndex = index;
    const photo = allPhotos[index];

    // Dim immediately — signals "something is loading"
    previewImg.classList.add('opacity-50');
    // Wire up the clear-on-load handler before assigning src
    previewImg.onload = () => previewImg.classList.remove('opacity-50');
    previewImg.src = photo.src;
    previewImg.alt = photo.alt;

    schedulePreload(index);

    // Scroll active thumb into view on the horizontal strip (mobile)
    const activeBtn = strip.querySelector(`[data-index="${index}"]`);
    if (activeBtn) activeBtn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });

    document.querySelectorAll('.thumb').forEach(btn => {
      const active = Number(btn.dataset.index) === index;
      btn.classList.toggle('ring-1', active);
      btn.classList.toggle('ring-[var(--color-accent)]', active);
      btn.classList.toggle('opacity-100', active);
      btn.classList.toggle('opacity-40', !active);
    });
  }

  function updatePhotoCount() {
    if (!photoCount) return;
    photoCount.textContent = `${allPhotos.length} photo${allPhotos.length !== 1 ? 's' : ''}`;
  }

  function updatePreviewArrows() {
    if (!previewPrev || !previewNext) return;
    const hide = allPhotos.length <= 1;
    previewPrev.style.display = hide ? 'none' : '';
    previewNext.style.display = hide ? 'none' : '';
  }

  window.previewNavigate = function(dir) {
    selectPhoto((activeIndex + dir + allPhotos.length) % allPhotos.length);
  };

  function addThumb(photo, index) {
    const btn = document.createElement('button');
    btn.className = 'thumb flex-shrink-0 w-16 h-16 overflow-hidden transition-opacity duration-150 opacity-40 hover:opacity-80 snap-start';
    btn.dataset.src   = photo.src;
    btn.dataset.alt   = photo.alt;
    btn.dataset.index = String(index);
    btn.setAttribute('aria-label', `View ${photo.alt}`);
    const img = document.createElement('img');
    img.src = photo.thumbSrc ?? photo.src;
    img.alt = photo.alt;
    img.className = 'w-full h-full object-cover';
    img.loading = 'lazy';
    btn.appendChild(img);
    btn.addEventListener('click', () => selectPhoto(index));
    strip.appendChild(btn);
  }

  // Bind existing thumbs
  document.querySelectorAll('.thumb').forEach(btn => {
    btn.addEventListener('click', () => selectPhoto(Number(btn.dataset.index)));
  });

  // ─── PROXIMITY-BASED PRELOADER ───────────────────────────────────────────
  // Maintains a priority queue of nearby full-res photos sorted by distance
  // from the active photo. When the active index changes, the queue rebuilds
  // so closer photos always win bandwidth over distant ones.
  //
  // Uses new Image() — shares the same browser cache as <img src>, unlike
  // fetch(). Concurrency is capped at 2 to avoid saturating bandwidth while
  // the user is actively browsing.
  const preloaded = new Set(); // srcs already loaded or in-flight
  let preloadQueue = [];
  let preloadActive = 0;
  const PRELOAD_CONCURRENCY = 2;
  const PRELOAD_WINDOW = 3; // preload ±3 photos around the active one

  function runPreloadQueue() {
    while (preloadActive < PRELOAD_CONCURRENCY && preloadQueue.length > 0) {
      const src = preloadQueue.shift();
      if (preloaded.has(src)) continue;
      preloaded.add(src);
      preloadActive++;
      const img = new Image();
      img.onload = img.onerror = () => {
        preloadActive--;
        runPreloadQueue(); // chain: fill slot when one completes
      };
      img.src = src;
    }
  }

  function schedulePreload(centerIdx) {
    // Priority order: +1, -1, +2, -2, ... — immediate neighbors first.
    // Replacing preloadQueue means in-flight loads finish (no wasted bandwidth)
    // but next slots are filled from the new position's priority order.
    preloadQueue = [];
    for (let d = 1; d <= PRELOAD_WINDOW; d++) {
      for (const idx of [centerIdx + d, centerIdx - d]) {
        const photo = allPhotos[idx];
        if (photo && !preloaded.has(photo.src)) preloadQueue.push(photo.src);
      }
    }
    runPreloadQueue();
  }

  // ─── LIGHTBOX ─────────────────────────────────────────────────────────────

  const lightbox      = document.getElementById('lightbox');
  const lightboxImg   = document.getElementById('lightbox-img');
  const lightboxLoader = document.getElementById('lightbox-loader');

  // ─── BLOCKER 2.2: Lightbox image loading fade ────────────────────────────
  // lightboxImg starts at opacity-0 (set in markup). Before assigning a new
  // src we: (1) show the loader, (2) wire up the onload handler that fades the
  // image in and hides the loader, THEN (3) set src. Order matters — onload
  // must be assigned before src or it can miss the event on cached images.
  const lightboxCounter = document.getElementById('lightbox-counter');

  function setLightboxImage(src, alt) {
    lightboxImg.classList.add('opacity-0');
    lightboxLoader.classList.remove('hidden');
    lightboxImg.onload = () => {
      lightboxImg.classList.remove('opacity-0');
      lightboxLoader.classList.add('hidden');
    };
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightboxCounter.textContent = `${activeIndex + 1} / ${allPhotos.length}`;
  }

  // ── Lightbox focus trap (2.4) ─────────────────────────────────────────────
  // Focusable elements inside the lightbox. Tab cycles only within these;
  // focus returns to the opener element when the lightbox closes.
  const lightboxFocusable = ['lightbox-close', 'lightbox-prev', 'lightbox-next']
    .map(id => document.getElementById(id));
  let lightboxOpener = null;

  window.openLightbox = function() {
    lightboxOpener = document.activeElement;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
    setLightboxImage(allPhotos[activeIndex].src, allPhotos[activeIndex].alt);
    document.getElementById('lightbox-close').focus();
  };

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
    if (lightboxOpener) { lightboxOpener.focus(); lightboxOpener = null; }
  }

  // Trap Tab/Shift+Tab within the lightbox
  lightbox.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const first = lightboxFocusable[0];
    const last  = lightboxFocusable[lightboxFocusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
    }
  });

  function lightboxPrev() {
    activeIndex = (activeIndex - 1 + allPhotos.length) % allPhotos.length;
    setLightboxImage(allPhotos[activeIndex].src, allPhotos[activeIndex].alt);
    schedulePreload(activeIndex);
    selectPhoto(activeIndex);
  }

  function lightboxNext() {
    activeIndex = (activeIndex + 1) % allPhotos.length;
    setLightboxImage(allPhotos[activeIndex].src, allPhotos[activeIndex].alt);
    schedulePreload(activeIndex);
    selectPhoto(activeIndex);
  }

  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev').addEventListener('click', lightboxPrev);
  document.getElementById('lightbox-next').addEventListener('click', lightboxNext);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

  // ── Swipe to navigate on mobile ──────────────────────────────────────────
  let swipeStartX = null;
  const SWIPE_THRESHOLD = 50;
  lightbox.addEventListener('touchstart', (e) => {
    swipeStartX = e.touches[0].clientX;
  }, { passive: true });
  lightbox.addEventListener('touchend', (e) => {
    if (swipeStartX === null) return;
    const delta = e.changedTouches[0].clientX - swipeStartX;
    swipeStartX = null;
    if (Math.abs(delta) < SWIPE_THRESHOLD) return;
    if (delta < 0) lightboxNext();
    else lightboxPrev();
  }, { passive: true });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) {
      closeLightbox();
    } else if (e.key === 'ArrowLeft') {
      if (!lightbox.classList.contains('hidden')) lightboxPrev();
      else selectPhoto((activeIndex - 1 + allPhotos.length) % allPhotos.length);
    } else if (e.key === 'ArrowRight') {
      if (!lightbox.classList.contains('hidden')) lightboxNext();
      else selectPhoto((activeIndex + 1) % allPhotos.length);
    }
  });

  // ─── PASSWORD GATE ────────────────────────────────────────────────────────

  if (isProtected) {
    const storageKey = `unlocked:${albumId}`;
    const gate = document.getElementById('password-gate');

    // Keep page scroll locked while gate is visible (skip if already unlocked via session)
    const alreadyUnlocked = sessionStorage.getItem(storageKey) === 'true';
    if (gate && !alreadyUnlocked) document.body.style.overflow = 'hidden';

    async function fetchAndUnlock() {
      const res = await fetch(`/api/albums/${albumId}/photos`);
      if (!res.ok) return false;
      const { photos: locked } = await res.json();
      const startIndex = allPhotos.length;
      locked.forEach((p, i) => {
        const photo = { src: p.src, thumbSrc: `${p.src}?w=300`, alt: p.alt };
        allPhotos.push(photo);
        addThumb(photo, startIndex + i);
      });
      updatePhotoCount();
      updatePreviewArrows();
      schedulePreload(activeIndex);
      return true;
    }

    function showGateError(msg) {
      // Re-show the gate if it was hidden (e.g. token expired on return visit)
      if (gate) {
        gate.style.opacity = '1';
        gate.style.display = '';
        document.body.style.overflow = 'hidden';
      }
      const btn = document.getElementById('unlock-btn');
      if (btn) { btn.disabled = false; btn.textContent = 'Unlock'; }
      const err = document.getElementById('password-error');
      if (err) { err.textContent = msg; err.classList.remove('hidden'); }
    }

    async function unlock(fromSessionStorage = false) {
      const ok = await fetchAndUnlock();
      if (!ok) {
        if (fromSessionStorage) {
          // Token likely expired — clear flag so gate prompts fresh
          sessionStorage.removeItem(storageKey);
        }
        showGateError('Something went wrong. Please try again.');
        return;
      }
      document.body.style.overflow = '';
      if (gate) {
        gate.style.opacity = '0';
        setTimeout(() => gate.remove(), 200);
      }
      document.getElementById('preview-btn')?.focus();
    }

    if (alreadyUnlocked) unlock(true);

    // ─── BLOCKER 2.7: Password gate button loading state ──────────────────
    // On submit: immediately disable the button and change its label to
    // "Unlocking…" so the user knows the request is in-flight and cannot
    // multi-submit during the server's enforced 1s delay. The button is only
    // re-enabled on failure (so the user can try again). On success we leave
    // it disabled — the gate hides anyway, so re-enabling is pointless.
    document.getElementById('password-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('unlock-btn');
      btn.disabled = true;
      btn.textContent = 'Unlocking…';

      const input = document.getElementById('password-input').value;
      const res = await fetch('/api/auth/album', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ album: albumId, password: input }),
      });

      if (res.ok) {
        // Keep button disabled — gate will hide once fetchAndUnlock() resolves
        sessionStorage.setItem(storageKey, 'true');
        unlock();
      } else {
        // Restore button so user can try again
        btn.disabled = false;
        btn.textContent = 'Unlock';
        const err = document.getElementById('password-error');
        err.classList.remove('hidden');
        document.getElementById('password-input').value = '';
        // Clear error on retype (bonus: 2.8)
        document.getElementById('password-input').addEventListener(
          'input',
          () => err.classList.add('hidden'),
          { once: true }
        );
      }
    });
  }
</script>
