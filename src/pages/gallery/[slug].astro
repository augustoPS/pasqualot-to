---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const albums = await getCollection('albums');
  return albums.map((album) => ({
    params: { slug: album.id },
    props: { album },
  }));
}

const { album } = Astro.props;
const { title, date, location, description, cover, photos, previewCount } = album.data;
const isProtected = album.data.protected;
const year = new Date(date).getFullYear();
const ogImage = `/photos/${album.id}/${cover}`;

const previewPhotos = isProtected ? photos.slice(0, previewCount) : photos;
const lockedCount = isProtected ? Math.max(0, photos.length - previewCount) : 0;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="text-2xl font-medium text-[var(--color-accent)]">{title}</h1>
      <p class="text-sm text-[var(--color-muted)] mt-1">
        {location ? `${location}, ` : ''}{year}
      </p>
      {description && (
        <p class="text-sm text-[var(--color-text)] mt-3 max-w-xl">{description}</p>
      )}
    </div>

    <!-- Preview photos (always visible) -->
    <div id="photo-grid" class="columns-1 sm:columns-2 md:columns-3 gap-3 space-y-3">
      {previewPhotos.map((photo, i) => (
        <button
          class="w-full break-inside-avoid cursor-zoom-in block"
          data-lightbox
          data-src={`/photos/${album.id}/${photo.file}`}
          data-alt={photo.alt}
          data-index={i}
          aria-label={`View ${photo.alt}`}
        >
          <img
            src={`/photos/${album.id}/${photo.file}`}
            alt={photo.alt}
            class="w-full transition-opacity duration-200 hover:opacity-80"
            loading="lazy"
          />
        </button>
      ))}

        <!-- Locked photos injected here by JS after authentication -->
    </div>

    <!-- Load more button (shown after unlock when more photos remain) -->
    <div id="load-more-wrap" class="mt-8 text-center" style="display:none">
      <button
        id="load-more-btn"
        class="px-6 py-2 text-sm border border-[var(--color-border)] text-[var(--color-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-muted)] transition-colors"
        onclick="loadMorePhotos()"
      >
        Load more
      </button>
      <p id="load-more-count" class="text-xs text-[var(--color-muted)] mt-2"></p>
    </div>

    <!-- Password gate -->
    {isProtected && (
      <div id="password-gate" class="mt-8 border border-[var(--color-border)] p-8 text-center">
        <p class="text-sm text-[var(--color-muted)] mb-1">
          {lockedCount} more photo{lockedCount !== 1 ? 's' : ''}
        </p>
        <p class="text-base text-[var(--color-text)] mb-6">Enter the password to view the full album</p>
        <form id="password-form" class="flex flex-col sm:flex-row gap-3 justify-center max-w-sm mx-auto">
          <input
            type="password"
            id="password-input"
            placeholder="Password"
            class="flex-1 bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text)] px-4 py-2 text-sm outline-none focus:border-[var(--color-muted)] placeholder:text-[var(--color-muted)]"
            autocomplete="current-password"
          />
          <button
            type="submit"
            class="px-6 py-2 text-sm bg-white text-black hover:bg-[var(--color-text)] transition-colors"
          >
            Unlock
          </button>
        </form>
        <p id="password-error" class="text-xs text-red-400 mt-3 hidden">Incorrect password.</p>
      </div>
    )}
  </div>

  <!-- Lightbox overlay -->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95"
    role="dialog"
    aria-modal="true"
    aria-label="Photo lightbox"
  >
    <button
      id="lightbox-close"
      class="absolute top-5 right-6 text-white/50 hover:text-white text-2xl leading-none transition-colors"
      aria-label="Close"
    >
      &#x2715;
    </button>
    <button
      id="lightbox-prev"
      class="absolute left-4 text-white/40 hover:text-white text-3xl leading-none transition-colors px-2 py-4"
      aria-label="Previous photo"
    >
      &#x2039;
    </button>
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-h-[90vh] max-w-[90vw] object-contain select-none"
    />
    <button
      id="lightbox-next"
      class="absolute right-4 text-white/40 hover:text-white text-3xl leading-none transition-colors px-2 py-4"
      aria-label="Next photo"
    >
      &#x203A;
    </button>
  </div>
</BaseLayout>

<script define:vars={{ isProtected, albumId: album.id, previewCount }}>
  // Lightbox
  function getVisiblePhotos() {
    return Array.from(document.querySelectorAll('[data-lightbox]:not(.hidden)')).map(el => ({
      src: el.dataset.src,
      alt: el.dataset.alt,
    }));
  }

  const lightbox = document.getElementById('lightbox');
  const img = document.getElementById('lightbox-img');
  let photos = getVisiblePhotos();
  let current = 0;

  function open(index) {
    photos = getVisiblePhotos();
    current = index;
    img.src = photos[current].src;
    img.alt = photos[current].alt;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function prev() { open((current - 1 + photos.length) % photos.length); }
  function next() { open((current + 1) % photos.length); }

  function bindPhotoButtons() {
    document.querySelectorAll('[data-lightbox]:not(.hidden)').forEach((btn, i) => {
      btn.onclick = () => open(i);
    });
  }
  bindPhotoButtons();

  document.getElementById('lightbox-close').addEventListener('click', close);
  document.getElementById('lightbox-prev').addEventListener('click', prev);
  document.getElementById('lightbox-next').addEventListener('click', next);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') prev();
    if (e.key === 'ArrowRight') next();
  });

  // Password gate
  if (isProtected) {
    const storageKey = `unlocked:${albumId}`;

    const PAGE_SIZE = 20;
    let allLockedPhotos = [];
    let loadedCount = 0;

    function injectPhotoBatch() {
      const grid = document.getElementById('photo-grid');
      const batch = allLockedPhotos.slice(loadedCount, loadedCount + PAGE_SIZE);
      batch.forEach((photo, i) => {
        const btn = document.createElement('button');
        btn.className = 'w-full break-inside-avoid cursor-zoom-in block';
        btn.dataset.lightbox = '';
        btn.dataset.src = photo.src;
        btn.dataset.alt = photo.alt;
        btn.dataset.index = String(previewCount + loadedCount + i);
        btn.setAttribute('aria-label', `View ${photo.alt}`);
        const imgEl = document.createElement('img');
        imgEl.src = photo.src;
        imgEl.alt = photo.alt;
        imgEl.className = 'w-full transition-opacity duration-200 hover:opacity-80';
        imgEl.loading = 'lazy';
        btn.appendChild(imgEl);
        grid.appendChild(btn);
      });
      loadedCount += batch.length;
      updateLoadMore();
      bindPhotoButtons();
    }

    function updateLoadMore() {
      const remaining = allLockedPhotos.length - loadedCount;
      const wrap = document.getElementById('load-more-wrap');
      const count = document.getElementById('load-more-count');
      if (remaining > 0) {
        wrap.style.display = 'block';
        count.textContent = `${loadedCount} of ${allLockedPhotos.length} photos loaded`;
      } else {
        wrap.style.display = 'none';
      }
    }

    window.loadMorePhotos = function() {
      injectPhotoBatch();
    };

    async function fetchAndInjectPhotos() {
      const res = await fetch(`/api/albums/${albumId}/photos`);
      if (!res.ok) return false;
      const { photos: lockedPhotos } = await res.json();
      allLockedPhotos = lockedPhotos;
      loadedCount = 0;
      injectPhotoBatch();
      return true;
    }

    async function unlock() {
      const ok = await fetchAndInjectPhotos();
      if (!ok) return;
      document.getElementById('password-gate').classList.add('hidden');
    }

    // Restore from session (cookie still valid for 24h)
    if (sessionStorage.getItem(storageKey) === 'true') {
      unlock();
    }

    document.getElementById('password-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = document.getElementById('password-input').value;
      const res = await fetch('/api/auth/album', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ album: albumId, password: input }),
      });
      if (res.ok) {
        sessionStorage.setItem(storageKey, 'true');
        unlock();
      } else {
        const err = document.getElementById('password-error');
        err.classList.remove('hidden');
        document.getElementById('password-input').value = '';
      }
    });
  }
</script>
