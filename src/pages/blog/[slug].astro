---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SHOW_BLOG } from '../../config';

export async function getStaticPaths() {
  if (!SHOW_BLOG) return [];
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, description } = post.data;
const { Content } = await render(post);
---

<BaseLayout title={title} description={description}>
  <article class="max-w-2xl mx-auto px-6 py-12">
    <header class="mb-10">
      <p class="text-xs text-[var(--color-muted)] mb-2">{date}</p>
      <h1 class="text-2xl font-medium text-[var(--color-accent)]">{title}</h1>
      {description && (
        <p class="text-sm text-[var(--color-muted)] mt-2">{description}</p>
      )}
    </header>
    <div class="prose prose-invert prose-sm max-w-none text-[var(--color-text)]">
      <Content />
    </div>
  </article>
</BaseLayout>
