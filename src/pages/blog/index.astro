---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SHOW_BLOG } from '../../config';

if (!SHOW_BLOG) {
  return Astro.redirect('/');
}

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Blog">
  <div class="max-w-2xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-medium text-[var(--color-accent)] mb-10">Blog</h1>
    <ul class="space-y-8">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`} class="group block">
            <p class="text-xs text-[var(--color-muted)] mb-1">{post.data.date}</p>
            <p class="text-base font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
              {post.data.title}
            </p>
            {post.data.description && (
              <p class="text-sm text-[var(--color-muted)] mt-1">{post.data.description}</p>
            )}
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
