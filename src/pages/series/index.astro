---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeriesCard from '../../components/home/SeriesCard.astro';
import { cdnUrl, cdnThumbUrl } from '../../lib/photos';

const allAlbums = await getCollection('albums');
const allCollections = await getCollection('albumCollections');

const childIds = new Set(allCollections.flatMap((c) => c.data.children));

const series = allCollections
  .filter((c) => !childIds.has(c.id) && !c.data.hidden)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

interface SeriesCardData {
  index: number;
  title: string;
  href: string;
  coverSrc: string;
  meta: string;
  albumCount: number;
  hasProtected: boolean;
  stackThumbs: { src: string; alt: string }[];
}

const cards: SeriesCardData[] = series.map((c, i) => {
  const childAlbums = c.data.children
    .map((id) => allAlbums.find((a) => a.id === id))
    .filter(Boolean);

  const stackThumbs = childAlbums.slice(0, 3).map((a) => ({
    src: cdnThumbUrl(a!.id, a!.data.cover),
    alt: a!.data.title,
  }));

  const year = new Date(c.data.date).getFullYear();
  const meta = c.data.location ? `${c.data.location} · ${year}` : String(year);

  return {
    index: i + 1,
    title: c.data.title,
    href: `/series/${c.id}`,
    coverSrc: cdnUrl(c.id, c.data.cover),
    meta,
    albumCount: childAlbums.length,
    hasProtected: childAlbums.some((a) => a!.data.protected),
    stackThumbs,
  };
});
const seriesCount = series.length;
const albumCount = allAlbums.length;
---

<BaseLayout title="Series">

  <!-- Header -->
  <div class="px-10 pt-14 pb-10">
    <p
      class="mb-4 ff-mono"
      style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);"
    >AUGUSTO PASQUALOTTO</p>
    <h1
      class="ff-serif"
      style="font-size: clamp(40px, 5vw, 60px); font-weight: 300; letter-spacing: -0.04em; line-height: 1.0; color: var(--color-ink);"
    >The<br />「<em style="font-style: italic; font-weight: 300; color: var(--color-accent);">Archive</em>」</h1>
    <p
      class="mt-3 ff-mono"
      style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);"
    >{seriesCount} SERIES · {albumCount} ALBUMS</p>
  </div>

  <!-- Grid -->
  <section class="px-10 pb-20" style="border-top: 1px solid var(--color-line); padding-top: 40px;">
    {cards.length === 0 ? (
      <p class="ff-serif" style="color: var(--color-meta); font-size: 14px;">No series yet.</p>
    ) : (
      <div class="flex flex-col md:grid md:grid-cols-3 max-w-[1200px] mx-auto" style="gap: 24px;">
        {cards.map((card) => (
          <SeriesCard {...card} />
        ))}
      </div>
    )}
  </section>

</BaseLayout>
