---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const albums = (await getCollection('albums')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout>
  <section class="max-w-5xl mx-auto px-6 py-12">
    {albums.length === 0 ? (
      <p class="text-[var(--color-muted)] text-sm">No albums yet.</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {albums.map((album) => (
          <a href={`/gallery/${album.id}`} class="group block overflow-hidden bg-[var(--color-surface)]">
            <div class="aspect-[4/3] overflow-hidden relative">
              <img
                src={`/photos/${album.id}/${album.data.cover}`}
                alt={album.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              {album.data.protected && (
                <span class="absolute bottom-2 left-2 text-[var(--color-muted)]" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                  </svg>
                  <span class="sr-only">Protected album</span>
                </span>
              )}
            </div>
            <div class="px-3 py-3">
              <p class="text-sm font-medium text-[var(--color-text)]">{album.data.title}</p>
              <p class="text-xs text-[var(--color-muted)] mt-0.5">
                {album.data.location && album.data.date
                  ? `${album.data.location} · ${new Date(album.data.date).getFullYear()}`
                  : album.data.location ?? new Date(album.data.date).getFullYear()}
              </p>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
