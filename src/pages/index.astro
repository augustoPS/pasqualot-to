---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/home/HomeHero.astro';
import SeriesCard from '../components/home/SeriesCard.astro';
import { cdnUrl, cdnThumbUrl } from '../lib/photos';

const allAlbums = await getCollection('albums');
const allCollections = await getCollection('albumCollections');

const childIds = new Set(allCollections.flatMap((c) => c.data.children));

const series = allCollections
  .filter((c) => !childIds.has(c.id) && !c.data.hidden)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

interface SeriesCardData {
  index: number;
  title: string;
  href: string;
  coverSrc: string;
  meta: string;
  albumCount: number;
  stackThumbs: { src: string; alt: string }[];
}

const cards: SeriesCardData[] = series.map((c, i) => {
  const childAlbums = c.data.children
    .map((id) => allAlbums.find((a) => a.id === id))
    .filter(Boolean);

  const stackThumbs = childAlbums.slice(0, 3).map((a) => ({
    src: cdnThumbUrl(a!.id, a!.data.cover),
    alt: a!.data.title,
  }));

  const year = new Date(c.data.date).getFullYear();
  const meta = c.data.location ? `${c.data.location} · ${year}` : String(year);

  return {
    index: i + 1,
    title: c.data.title,
    href: `/gallery/${c.id}`,
    coverSrc: cdnUrl(c.id, c.data.cover),
    meta,
    albumCount: childAlbums.length,
    stackThumbs,
  };
});
---

<BaseLayout>
  <HomeHero />

  <section class="px-10 pb-24 max-w-[1200px] mx-auto">
    <p
      class="mb-8"
      style="font-family: var(--font-mono); font-size: 10px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);"
    >
      Albums —
    </p>

    {cards.length === 0 ? (
      <p style="color: var(--color-meta); font-size: 14px;">No series yet.</p>
    ) : (
      <div class="flex flex-col md:grid md:grid-cols-2" style="gap: 20px;">
        {cards.map((card, i) => (
          <div
            class="md:contents"
            style={`width: 80%; ${i % 2 === 0 ? 'margin-left: 20%;' : 'margin-right: 20%;'}`}
          >
            <SeriesCard {...card} />
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
