---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="max-w-xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-medium text-[var(--color-accent)] mb-8">About</h1>
    <div class="space-y-4 text-sm text-[var(--color-text)] leading-relaxed">
      <p>
        Hi, I'm Pasqualotto. I take photos and build things.
      </p>
      <p>
        This site is a place for my photography, notes, and personal projects.
      </p>
    </div>
  </div>
</BaseLayout>
