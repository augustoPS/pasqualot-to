---
import BaseLayout from '../layouts/BaseLayout.astro';

const aboutPhotoSrc = 'https://photos.pasqualo.to/about/portrait.jpg';
---

<BaseLayout title="About" breadcrumbs={[{ label: 'About' }]}>
  <section class="grid grid-cols-1 md:grid-cols-[1fr_1.1fr] min-h-[calc(100vh-64px)]">

    <!-- Photo column -->
    <div class="relative overflow-hidden" style="min-height: 300px;">
      <img
        src={aboutPhotoSrc}
        alt="Augusto Pasqualoto"
        class="absolute inset-0 w-full h-full object-cover object-top"
      />
    </div>

    <!-- Text column -->
    <div
      class="flex flex-col justify-end px-10 md:px-16 py-16 md:py-20"
      style="max-width: 600px;"
    >
      <p
        class="mb-8"
        style="font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-accent);"
      >COLOPHON</p>

      <h1
        class="mb-10"
        style="font-family: 'Fraunces', Georgia, serif; font-size: clamp(48px, 6vw, 80px); font-weight: 400; letter-spacing: -0.04em; line-height: 1.0; color: var(--color-ink);"
      >Augusto<br /><em>Pasqualotto.</em></h1>

      <div
        class="space-y-5"
        style="font-family: 'Inter', ui-sans-serif, system-ui, sans-serif; font-size: 17px; font-weight: 300; line-height: 1.7; color: var(--color-ink-muted);"
      >
        <p>
          Porto Alegre · hobbyist photographer. I shoot what's nearby — cats,
          circus people, friends running, action figures in afternoon light.
        </p>
        <p>
          The <a href="https://shop.pasqualo.to" target="_blank" rel="noopener noreferrer" style="color: var(--color-ink-muted); text-decoration: underline; text-underline-offset: 3px;">shop</a> is a side project — I photograph public events and people doing
          things they love, and let them find themselves afterwards.
        </p>
        <p>
          Some albums are private. Ask if you know me.
        </p>
      </div>

      <div class="mt-14">
        <p
          class="mb-4"
          style="font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-dim);"
        >Contact —</p>
        <div
          class="flex flex-col gap-2"
          style="font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.10em; color: var(--color-meta);"
        >
          <a
            href="mailto:gutao.paska@gmail.com"
            class="hover:text-[var(--color-ink)] transition-colors"
            style="text-decoration: none;"
          >email — gutao.paska@gmail.com</a>
          <a
            href="https://instagram.com/augustops_"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-ink)] transition-colors"
            style="text-decoration: none;"
          >instagram — @augustops_</a>
          <a
            href="https://github.com/augustoPS"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-ink)] transition-colors"
            style="text-decoration: none;"
          >github — augustoPS</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

