---
import BaseLayout from '../layouts/BaseLayout.astro';

const orientation = import.meta.env.PUBLIC_ABOUT_PHOTO_ORIENTATION ?? 'portrait';
const isLandscape = orientation === 'landscape';
const aboutPhotoSrc = `https://photos.pasqualo.to/about/${orientation}.jpg`;
---

<BaseLayout title="About" breadcrumbs={[{ label: 'About' }]}>
  <section
    class={isLandscape
      ? 'grid grid-cols-1 md:grid-cols-[2fr_1fr] h-[calc(100vh-64px)] overflow-hidden'
      : 'grid grid-cols-1 md:grid-cols-[1fr_1.1fr] h-[calc(100vh-64px)] overflow-hidden'}
  >

    <!-- Photo -->
    <div
      class="relative overflow-hidden max-h-full"
      style={isLandscape ? 'aspect-ratio: 16/9;' : 'aspect-ratio: 4/5; min-height: 300px;'}
    >
      <img
        src={aboutPhotoSrc}
        alt="Augusto Pasqualoto"
        style={isLandscape ? 'clip-path: inset(0 10%);' : ''}
        class={`absolute inset-0 w-full h-full object-cover ${isLandscape ? 'object-center' : 'object-top'}`}
      />
    </div>

    <!-- Text column -->
    <div
      class="flex flex-col px-10 md:px-16 py-6 md:py-8"
      style="max-width: 600px;"
    >
      <p
        class="mb-2 ff-mono"
        style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-accent);"
      >COLOPHON</p>

      <h1
        class="mb-4 ff-serif"
        style="font-size: clamp(36px, 5vw, 56px); font-weight: 400; letter-spacing: -0.04em; line-height: 1.0; color: var(--color-ink);"
      >Augusto<br /><em>Pasqualotto.</em></h1>

      <div
        class="space-y-2 ff-serif"
        style="font-size: 16px; font-weight: 300; line-height: 1.5; color: var(--color-ink-muted);"
      >
        <p>
          Porto Alegre · hobbyist photographer. I shoot what's nearby — cats,
          circus people, friends running, action figures in afternoon light.
        </p>
        <p>
          The <a href="https://shop.pasqualo.to" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--color-dim);">shop</a> is a side project — I photograph public events and people doing
          things they love, and let them find themselves afterwards.
        </p>
        <p>
          Some albums are private. Ask if you know me.
        </p>
      </div>

      <div class="mt-6 pt-3 border-t" style="border-color: var(--color-line-2);">
        <div class="ff-mono" style="display: grid; grid-template-columns: auto 1fr; gap: 2px 16px; font-size: 9px; letter-spacing: 0.12em;">
          <span style="text-transform: uppercase; color: var(--color-dim);">Email</span>
          <span style="color: var(--color-meta);">
            <a href="mailto:hello@pasqualo.to" style="color: inherit; text-decoration: none;">hello@pasqualo.to</a>
          </span>
          <span style="text-transform: uppercase; color: var(--color-dim);">Instagram</span>
          <span style="color: var(--color-meta);">
            <a href="https://instagram.com/pasqualot.to" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: none;">@pasqualot.to</a>
          </span>
          <span style="text-transform: uppercase; color: var(--color-dim);">Shop</span>
          <span style="color: var(--color-meta);">
            <a href="https://shop.pasqualo.to" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: none;">shop.pasqualo.to</a>
          </span>
          <span style="text-transform: uppercase; color: var(--color-dim);">Built with</span>
          <span style="color: var(--color-meta);">claude code · astro · r2 · </span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
