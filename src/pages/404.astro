---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { cdnUrl } from '../lib/photos';

const allAlbums = await getCollection('albums');
const publicAlbums = allAlbums.filter((a) => !a.data.protected && a.data.photos.length > 0);

let randomPhoto = { src: '', alt: '', albumTitle: '', albumDate: '' };
if (publicAlbums.length > 0) {
  const album = publicAlbums[Math.floor(Math.random() * publicAlbums.length)];
  const photo = album.data.photos[Math.floor(Math.random() * album.data.photos.length)];
  const albumDateObj = new Date(album.data.date);
  randomPhoto = {
    src: cdnUrl(album.id, photo.file),
    alt: photo.alt,
    albumTitle: album.data.title,
    albumDate: albumDateObj.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }),
  };
}
---

<BaseLayout title="404" breadcrumbs={[{ label: '404' }]}>
  <section class="min-h-[calc(100vh-64px)] grid grid-cols-1 md:grid-cols-[1fr_1.05fr]">

    <!-- Left: random photo -->
    <div class="relative overflow-hidden" style="aspect-ratio: 4/5; min-height: 320px;">
      {randomPhoto.src && (
        <img
          src={randomPhoto.src}
          alt={randomPhoto.alt}
          class="absolute inset-0 w-full h-full object-cover"
        />
      )}
    </div>

    <!-- Right: copy -->
    <div class="flex flex-col justify-center px-8 md:px-16 py-20">

      <!-- Kicker — three tones -->
      <p class="nf-copy nf-photographic mb-6 ff-mono" style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);">404 — NOT FOUND</p>
      <p class="nf-copy nf-dry hidden mb-6 ff-mono" style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);">404 — NOT FOUND</p>
      <p class="nf-copy nf-warm hidden mb-6 ff-mono" style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);">HEY.</p>

      <!-- Headline (same across tones) -->
      <h1
        class="mb-4 ff-serif"
        style="font-weight: 400; letter-spacing: -0.04em; line-height: 1.0; color: var(--color-ink); font-size: clamp(80px, 10vw, 124px);"
      >4<em style="color: var(--color-accent);">0</em>4</h1>

      <!-- Sub-kicker — three tones -->
      <p class="nf-copy nf-photographic mb-6 ff-mono" style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);">FRAME NOT FOUND</p>
      <p class="nf-copy nf-dry hidden mb-6 ff-mono" style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);">FILE MISSING</p>
      <p class="nf-copy nf-warm hidden mb-6 ff-mono" style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);">WRONG TURN</p>

      <!-- Body — three tones -->
      <div class="nf-copy nf-photographic ff-serif" style="font-size: 19px; line-height: 1.6; color: var(--color-ink-muted); max-width: 420px;">
        <p>
          The negative you're looking for isn't in the binder.
          While you're here — a frame from <em>{randomPhoto.albumTitle || 'the archive'}</em>
          {randomPhoto.albumDate && `, ${randomPhoto.albumDate}`}.
        </p>
      </div>
      <div class="nf-copy nf-dry hidden ff-serif" style="font-size: 19px; line-height: 1.6; color: var(--color-ink-muted); max-width: 420px;">
        <p>
          Wrong folder. Whatever it was, it's not here.
          This frame is, though — from <em>{randomPhoto.albumTitle || 'the archive'}</em>
          {randomPhoto.albumDate && `, ${randomPhoto.albumDate}`}.
        </p>
      </div>
      <div class="nf-copy nf-warm hidden ff-serif" style="font-size: 19px; line-height: 1.6; color: var(--color-ink-muted); max-width: 420px;">
        <p>
          You ended up somewhere you didn't mean to — happens to the best of us.
          While you're here, here's a frame from <em>{randomPhoto.albumTitle || 'the archive'}</em>
          {randomPhoto.albumDate && `, ${randomPhoto.albumDate}`}.
        </p>
      </div>

      <!-- Tone switcher pills -->
      <div class="mt-8 flex items-center gap-3">
        <button data-tone="photographic" class="nf-tone-btn ff-mono" style="font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; padding: 5px 10px; border: 1px solid var(--color-line-2); background: var(--color-ink); color: var(--color-bg); cursor: pointer;">PHOTOGRAPHIC</button>
        <button data-tone="dry" class="nf-tone-btn ff-mono" style="font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; padding: 5px 10px; border: 1px solid var(--color-line-2); background: transparent; color: var(--color-meta); cursor: pointer;">DRY</button>
        <button data-tone="warm" class="nf-tone-btn ff-mono" style="font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; padding: 5px 10px; border: 1px solid var(--color-line-2); background: transparent; color: var(--color-meta); cursor: pointer;">WARM</button>
      </div>

      <!-- Recovery links -->
      <div class="mt-10 flex items-center gap-8">
        <a
          href="/"
          class="ff-display"
          style="font-size: 12px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink); text-decoration: none; border: 1px solid var(--color-line-2); display: inline-block; padding: 10px 20px; transition: border-color 0.15s;"
        >← BACK TO GALLERY</a>
        <a
          href="/"
          class="ff-display"
          style="font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta); text-decoration: none;"
        >SEE THE SERIES ARCHIVE</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const toneButtons = document.querySelectorAll<HTMLButtonElement>('.nf-tone-btn');

  toneButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tone = btn.dataset.tone;
      if (!tone) return;

      // Toggle copy blocks
      document.querySelectorAll('.nf-copy').forEach((el) => {
        (el as HTMLElement).classList.toggle('hidden', !el.classList.contains(`nf-${tone}`));
      });

      // Update button active state
      toneButtons.forEach((b) => {
        const isActive = b.dataset.tone === tone;
        b.style.background = isActive ? 'var(--color-ink)' : 'transparent';
        b.style.color = isActive ? 'var(--color-bg)' : 'var(--color-meta)';
      });
    });
  });
</script>
