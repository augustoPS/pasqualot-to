---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { cdnUrl } from '../lib/photos';

const allAlbums = await getCollection('albums');
const publicAlbums = allAlbums.filter((a) => !a.data.protected && a.data.photos.length > 0);

let randomPhoto = { src: '', alt: '', albumTitle: '', albumDate: '' };
if (publicAlbums.length > 0) {
  const album = publicAlbums[Math.floor(Math.random() * publicAlbums.length)];
  const photo = album.data.photos[Math.floor(Math.random() * album.data.photos.length)];
  const albumDateObj = new Date(album.data.date);
  randomPhoto = {
    src: cdnUrl(album.id, photo.file),
    alt: photo.alt,
    albumTitle: album.data.title,
    albumDate: albumDateObj.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }),
  };
}
---

<BaseLayout title="404" breadcrumbs={[{ label: '404' }]}>
  <section class="min-h-[calc(100vh-64px)] grid grid-cols-1 md:grid-cols-[1fr_1.05fr]">

    <!-- Left: random photo -->
    <div class="relative overflow-hidden" style="aspect-ratio: 4/5; min-height: 320px;">
      {randomPhoto.src && (
        <img
          src={randomPhoto.src}
          alt={randomPhoto.alt}
          class="absolute inset-0 w-full h-full object-cover"
        />
      )}
    </div>

    <!-- Right: copy -->
    <div class="flex flex-col justify-center px-16 py-20">

      <!-- Kicker -->
      <p
        class="mb-6"
        style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);"
      >404 — NOT FOUND</p>

      <!-- Display headline -->
      <h1
        class="mb-4"
        style="font-family: var(--font-serif); font-weight: 400; letter-spacing: -0.04em; line-height: 1.0; color: var(--color-ink); font-size: clamp(80px, 10vw, 124px);"
      >4<em style="color: var(--color-accent);">0</em>4</h1>

      <!-- Sub-kicker -->
      <p
        class="mb-6"
        style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);"
      >FRAME NOT FOUND</p>

      <!-- Body copy -->
      <div style="font-family: var(--font-serif); font-size: 19px; line-height: 1.6; color: var(--color-ink-muted); max-width: 420px;">
        <p>
          The negative you're looking for isn't in the binder.
          While you're here — a frame from <em>{randomPhoto.albumTitle || 'the archive'}</em>
          {randomPhoto.albumDate && `, ${randomPhoto.albumDate}`}.
        </p>
      </div>

      <!-- Recovery links -->
      <div class="mt-10 flex items-center gap-8">
        <a
          href="/"
          style="font-family: var(--font-sans); font-size: 12px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink); text-decoration: none; border: 1px solid var(--color-line-2); display: inline-block; padding: 10px 20px; transition: border-color 0.15s;"
        >← BACK TO GALLERY</a>
        <a
          href="/gallery"
          style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta); text-decoration: none;"
        >SEE THE SERIES ARCHIVE</a>
      </div>
    </div>
  </section>
</BaseLayout>

