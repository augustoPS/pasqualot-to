---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { cdnUrl } from '../lib/photos';

const allAlbums = await getCollection('albums');
const publicAlbums = allAlbums.filter((a) => !a.data.protected && a.data.photos.length > 0);

let randomPhoto = { src: '', alt: '', albumTitle: '' };
if (publicAlbums.length > 0) {
  const album = publicAlbums[Math.floor(Math.random() * publicAlbums.length)];
  const photo = album.data.photos[Math.floor(Math.random() * album.data.photos.length)];
  randomPhoto = {
    src: cdnUrl(album.id, photo.file),
    alt: photo.alt,
    albumTitle: album.data.title,
  };
}
---

<BaseLayout title="404" breadcrumbs={[{ label: '404' }]}>
  <section class="min-h-[calc(100vh-64px)] grid grid-cols-1 md:grid-cols-[1fr_1.05fr]">

    <!-- Left: random photo -->
    <div class="relative overflow-hidden" style="aspect-ratio: 4/5; min-height: 320px;">
      {randomPhoto.src && (
        <img
          src={randomPhoto.src}
          alt={randomPhoto.alt}
          class="absolute inset-0 w-full h-full object-cover"
        />
      )}
    </div>

    <!-- Right: copy -->
    <div class="flex flex-col justify-center px-16 py-20">

      <!-- Kicker -->
      <p
        class="mb-6"
        style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);"
      >
        <span class="nf-copy nf-photographic">frame not found</span>
        <span class="nf-copy nf-dry hidden">404.</span>
        <span class="nf-copy nf-warm hidden"></span>
      </p>

      <!-- Display headline -->
      <h1
        class="mb-8"
        style="font-family: var(--font-serif); font-weight: 400; letter-spacing: -0.04em; line-height: 1.0; color: var(--color-ink);"
      >
        <span
          class="nf-copy nf-photographic block"
          style="font-size: clamp(80px, 10vw, 124px);"
        >4<em style="color: var(--color-accent);">0</em>4</span>
        <span
          class="nf-copy nf-dry hidden block"
          style="font-size: clamp(80px, 10vw, 124px);"
        >404<em style="color: var(--color-accent);">.</em></span>
        <span
          class="nf-copy nf-warm hidden block"
          style="font-size: clamp(36px, 5vw, 52px);"
        ><em>This page</em> isn't here.</span>
      </h1>

      <!-- Body copy -->
      <div style="font-family: var(--font-serif); font-size: 19px; line-height: 1.6; color: var(--color-ink-muted); max-width: 420px;">
        <p class="nf-copy nf-photographic">
          The negative you're looking for isn't in the binder.
          While you're here — a frame from <em>{randomPhoto.albumTitle || 'the archive'}</em>.
        </p>
        <p class="nf-copy nf-dry hidden" style="font-size: 17px;">
          Nothing here. <em>Try the gallery.</em>
        </p>
        <p
          class="nf-copy nf-warm hidden"
          style="font-family: var(--font-sans); font-size: 16px; font-weight: 300;"
        >
          Maybe I moved it. Maybe the link was old. Either way — here's a photo
          from the archive while you figure out where you were headed. — Augusto
        </p>
      </div>

      <!-- Recovery links -->
      <div class="mt-10 flex flex-col gap-3">
        <a
          href="/"
          style="font-family: var(--font-sans); font-size: 12px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink); text-decoration: none; border: 1px solid var(--color-line-2); display: inline-block; padding: 10px 20px; width: fit-content; transition: border-color 0.15s;"
        >← back to gallery</a>
        <a
          href="/about"
          style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-meta); text-decoration: none;"
        >contact</a>
      </div>

      <!-- Tone switcher -->
      <div class="mt-16 flex gap-1" role="group" aria-label="Copy tone">
        <button data-tone="photographic" class="tone-btn px-3 py-1 tone-active" style="font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; border: 1px solid var(--color-line-2); background: var(--color-surface-2); color: var(--color-ink); cursor: pointer;">photographic</button>
        <button data-tone="dry" class="tone-btn px-3 py-1" style="font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; border: 1px solid var(--color-line); background: transparent; color: var(--color-dim); cursor: pointer;">dry</button>
        <button data-tone="warm" class="tone-btn px-3 py-1" style="font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; border: 1px solid var(--color-line); background: transparent; color: var(--color-dim); cursor: pointer;">warm</button>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.tone-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tone = btn.dataset.tone;
      if (!tone) return;

      document.querySelectorAll('.nf-copy').forEach((el) => {
        (el as HTMLElement).classList.toggle('hidden', !el.classList.contains(`nf-${tone}`));
      });

      document.querySelectorAll<HTMLButtonElement>('.tone-btn').forEach((b) => {
        const active = b.dataset.tone === tone;
        b.style.background = active ? 'var(--color-surface-2)' : 'transparent';
        b.style.color = active ? 'var(--color-ink)' : 'var(--color-dim)';
        b.style.borderColor = active ? 'var(--color-line-2)' : 'var(--color-line)';
      });
    });
  });
</script>
