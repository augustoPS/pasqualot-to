---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { cdnUrl } from '../lib/photos';

const allAlbums = await getCollection('albums');
const publicAlbums = allAlbums.filter((a) => !a.data.protected && a.data.photos.length > 0);

let randomPhoto = { src: '', alt: '', albumTitle: '', albumDate: '' };
if (publicAlbums.length > 0) {
  const album = publicAlbums[Math.floor(Math.random() * publicAlbums.length)];
  const photo = album.data.photos[Math.floor(Math.random() * album.data.photos.length)];
  const albumDateObj = new Date(album.data.date);
  randomPhoto = {
    src: cdnUrl(album.id, photo.file),
    alt: photo.alt,
    albumTitle: album.data.title,
    albumDate: albumDateObj.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }),
  };
}
---

<BaseLayout title="404" breadcrumbs={[{ label: '404' }]}>
  <section
    class="grid grid-cols-1 grid-rows-[2fr_3fr] md:grid-cols-[1fr_1.05fr] md:grid-rows-1"
    style="height: calc(100vh - var(--nav-h));"
  >

    <!-- Photo: band on mobile, full left column on desktop -->
    <div class="relative overflow-hidden">
      {randomPhoto.src && (
        <img
          src={randomPhoto.src}
          alt={randomPhoto.alt}
          class="absolute inset-0 w-full h-full object-cover"
        />
      )}
    </div>

    <!-- Right: copy -->
    <div class="flex flex-col justify-center px-8 md:px-16 py-8 md:py-20">

      <!-- Headline -->
      <h1
        class="mb-4 ff-serif"
        style="font-weight: 400; letter-spacing: -0.04em; line-height: 1.0; color: var(--color-ink); font-size: clamp(80px, 10vw, 124px);"
      >4<em style="color: var(--color-accent);">0</em>4</h1>

      <!-- Sub-kicker -->
      <p class="mb-6 ff-mono" style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);">FRAME NOT FOUND</p>

      <!-- Body -->
      <div class="ff-serif" style="font-size: 21px; line-height: 1.6; color: var(--color-ink-muted); max-width: 420px;">
        <p>
          The negative you're looking for isn't in the binder.
          While you're here — a frame from <em>{randomPhoto.albumTitle || 'the archive'}</em>
          {randomPhoto.albumDate && `, ${randomPhoto.albumDate}`}.
        </p>
      </div>

      <!-- Recovery links -->
      <div class="mt-10 flex items-center gap-8">
        <a
          href="/"
          class="ff-mono"
          style="font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta); text-decoration: none; display: inline-block;"
        >← BACK HOME</a>
        <a
          href="/series"
          class="ff-mono"
          style="font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta); text-decoration: none; display: inline-block;"
        >SEE THE ARCHIVE</a>
      </div>
    </div>
  </section>
</BaseLayout>
