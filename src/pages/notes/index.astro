---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SHOW_NOTES } from '../../config';

if (!SHOW_NOTES) return Astro.redirect('/', 302);

const notes = (await getCollection('notes')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Notes" breadcrumbs={[{ label: 'Notes' }]}>
  <div class="max-w-2xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-medium text-[var(--color-accent)] mb-10">Notes</h1>
    <ul class="space-y-6">
      {notes.map((note) => (
        <li>
          <a href={`/notes/${note.id}`} class="group block">
            <p class="text-xs text-[var(--color-muted)] mb-1">{note.data.date}</p>
            <p class="text-base font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
              {note.data.title}
            </p>
          </a>
        </li>
      ))}
      {notes.length === 0 && (
        <p class="text-sm text-[var(--color-muted)]">Nothing here yet.</p>
      )}
    </ul>
  </div>
</BaseLayout>
