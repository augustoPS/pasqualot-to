---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { title, date } = note.data;
const { Content } = await render(note);
---

<BaseLayout title={title}>
  <article class="max-w-2xl mx-auto px-6 py-12">
    <header class="mb-8">
      <p class="text-xs text-[var(--color-muted)] mb-2">{date}</p>
      <h1 class="text-2xl font-medium text-[var(--color-accent)]">{title}</h1>
    </header>
    <div class="prose prose-invert prose-sm max-w-none text-[var(--color-text)]">
      <Content />
    </div>
  </article>
</BaseLayout>
