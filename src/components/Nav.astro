---
import { SITE_NAME, SHOW_BLOG, SHOW_NOTES } from '../config';

const links = [
  { href: '/', label: 'Gallery' },
  ...(SHOW_BLOG ? [{ href: '/blog', label: 'Blog' }] : []),
  ...(SHOW_NOTES ? [{ href: '/notes', label: 'Notes' }] : []),
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<nav class="flex items-center justify-between px-6 py-5 border-b border-[var(--color-border)] relative">
  <a href="/" class="text-sm font-medium tracking-widest uppercase text-[var(--color-accent)] hover:opacity-70 transition-opacity">
    {SITE_NAME}
  </a>

  <!-- Desktop links -->
  <ul class="hidden sm:flex gap-6">
    {links.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class:list={[
            'text-sm transition-colors',
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'text-[var(--color-accent)]'
              : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
          ]}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Mobile hamburger -->
  <button
    id="nav-toggle"
    class="sm:hidden flex flex-col gap-1.5 p-1"
    aria-label="Toggle menu"
    aria-expanded="false"
  >
    <span class="block w-5 h-px bg-[var(--color-text)] transition-all"></span>
    <span class="block w-5 h-px bg-[var(--color-text)] transition-all"></span>
    <span class="block w-5 h-px bg-[var(--color-text)] transition-all"></span>
  </button>
</nav>

<!-- Mobile menu panel -->
<div
  id="nav-menu"
  class="hidden sm:hidden border-b border-[var(--color-border)] bg-[var(--color-bg)]"
>
  <ul class="flex flex-col px-6 py-4 gap-4">
    {links.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class:list={[
            'text-sm transition-colors',
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'text-[var(--color-accent)]'
              : 'text-[var(--color-muted)]',
          ]}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
