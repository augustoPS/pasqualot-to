---
import { SITE_NAME, SHOW_BLOG, SHOW_NOTES } from '../config';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  breadcrumbs?: Crumb[];
}

const { breadcrumbs = [] } = Astro.props;

const links = [
  { href: '/', label: 'gallery' },
  ...(SHOW_NOTES ? [{ href: '/notes', label: 'notes' }] : []),
  { href: 'https://shop.pasqualo.to', label: 'shop' },
  { href: '/about', label: 'about' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string, label: string): boolean {
  if (label === 'gallery') return currentPath === '/' || currentPath.startsWith('/gallery');
  if (href.startsWith('http')) return false;
  return currentPath === href || (href !== '/' && currentPath.startsWith(href));
}
---

<header
  class="sticky top-0 z-40 flex items-center justify-between px-10 py-5 border-b"
  style="border-color: var(--color-line); background-color: var(--color-bg);"
>
  <!-- Left: logo + breadcrumb -->
  <div class="flex items-center min-w-0 flex-1 mr-8">
    <a
      href="/"
      class="shrink-0"
      style="font-family: var(--font-mono); font-size: 10px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-ink); text-decoration: none;"
    >
      {SITE_NAME}
    </a>
    {breadcrumbs.map((crumb, i) => {
      const isLast = i === breadcrumbs.length - 1;
      return (
        <>
          <span
            class="mx-2 hidden sm:inline"
            style="font-family: var(--font-mono); font-size: 10px; color: var(--color-dim);"
          >/</span>
          {isLast ? (
            <span
              class="hidden sm:inline overflow-hidden text-ellipsis whitespace-nowrap"
              style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: lowercase; color: var(--color-meta);"
            >{crumb.label.toLowerCase()}</span>
          ) : (
            <a
              href={crumb.href}
              class="hidden sm:inline whitespace-nowrap"
              style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: lowercase; color: var(--color-meta); text-decoration: none; opacity: 0.8;"
            >{crumb.label.toLowerCase()}</a>
          )}
        </>
      );
    })}
  </div>

  <!-- Desktop nav links -->
  <nav class="hidden sm:flex items-center gap-8 shrink-0">
    {links.map(({ href, label }) => (
      <a
        href={href}
        target={href.startsWith('http') ? '_blank' : undefined}
        rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
        style={`font-family: var(--font-sans); font-size: 13px; font-weight: 400; letter-spacing: 0.02em; color: ${isActive(href, label) ? 'var(--color-ink)' : 'var(--color-meta)'}; text-decoration: none; border-bottom: ${isActive(href, label) ? '1px solid var(--color-accent)' : 'none'}; padding-bottom: ${isActive(href, label) ? '2px' : '0'}; transition: color 0.15s;`}
      >
        {label}
      </a>
    ))}
  </nav>

  <!-- Mobile hamburger -->
  <button
    id="nav-toggle"
    class="sm:hidden p-1 shrink-0"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="nav-drawer"
    style="background: none; border: none; cursor: pointer;"
  >
    <span class="block w-5 h-px mb-1.5" style="background: var(--color-ink);"></span>
    <span class="block w-5 h-px mb-1.5" style="background: var(--color-ink);"></span>
    <span class="block w-5 h-px" style="background: var(--color-ink);"></span>
  </button>
</header>

<!-- Mobile drawer -->
<div
  id="nav-drawer"
  class="fixed inset-0 z-50 hidden flex-col"
  style="background-color: var(--color-bg);"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
>
  <div
    class="flex items-center justify-between px-10 py-5 border-b"
    style="border-color: var(--color-line);"
  >
    <span style="font-family: var(--font-mono); font-size: 10px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-ink);">
      {SITE_NAME}
    </span>
    <button
      id="nav-close"
      class="p-1"
      aria-label="Close menu"
      style="font-family: var(--font-mono); font-size: 24px; color: var(--color-meta); background: none; border: none; cursor: pointer; line-height: 1;"
    >×</button>
  </div>
  <nav class="flex flex-col px-10 pt-12 gap-8">
    {links.map(({ href, label }) => (
      <a
        href={href}
        target={href.startsWith('http') ? '_blank' : undefined}
        rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
        style={`font-family: var(--font-serif); font-size: 32px; color: ${isActive(href, label) ? 'var(--color-ink)' : 'var(--color-meta)'}; text-decoration: none;`}
      >
        {label}
      </a>
    ))}
  </nav>
</div>

<script>
  const toggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('nav-drawer');
  const closeBtn = document.getElementById('nav-close');

  function openDrawer() {
    drawer?.classList.remove('hidden');
    drawer?.classList.add('flex');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer?.classList.add('hidden');
    drawer?.classList.remove('flex');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDrawer();
  });
</script>
