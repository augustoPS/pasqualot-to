---
import { SHOW_NOTES } from '../config';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  breadcrumbs?: Crumb[];
}

const { breadcrumbs = [] } = Astro.props;

const links = [
  { href: '/series', label: 'series' },
  ...(SHOW_NOTES ? [{ href: '/notes', label: 'notes' }] : []),
  { href: 'https://shop.pasqualo.to', label: 'shop' },
  { href: '/about', label: 'about' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string, label: string): boolean {
  if (label === 'series') return currentPath === '/series' || currentPath.startsWith('/series/');
  if (href.startsWith('http')) return false;
  return currentPath === href || (href !== '/' && currentPath.startsWith(href));
}

const hasBreadcrumbs = breadcrumbs.length > 0;
---

<header
  class="sticky top-0 z-40 border-b"
  style="border-color: var(--color-line); background-color: var(--color-bg);"
>
  <div class="flex items-center justify-between px-6 md:px-10 py-5">

    <!-- Logo with optional inline breadcrumb path (breadcrumbs hidden below sm) -->
    <div class="flex items-center">
      <a href="/" class="logo" aria-label="pasqualo.to home">
        <span class="logo-mark" aria-hidden="true">
          <svg class="bracket bracket--tl" width="10" height="10" viewBox="0 0 14 14" fill="none">
            <path d="M 1 5 L 1 1 L 5 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
          </svg>
          <span class="wordmark">
            <span class="wordmark__name">pasqualo</span><span class="wordmark__tld">.to</span>
          </span>
          <svg class="bracket bracket--br" width="10" height="10" viewBox="0 0 14 14" fill="none">
            <path d="M 13 9 L 13 13 L 9 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
          </svg>
        </span>
      </a>
      {hasBreadcrumbs && breadcrumbs.map((crumb, i) => {
        const isLast = i === breadcrumbs.length - 1;
        return (
          <>
            <span
              class="hidden sm:inline ff-display"
              style="color: var(--color-dim); font-weight: 300; margin: 0 6px; font-size: 15px;"
            >/</span>
            {isLast ? (
              <span class="hidden sm:inline ff-display" style="font-size: 15px; font-weight: 500; letter-spacing: -0.02em; color: var(--color-ink);">{crumb.label.toLowerCase()}</span>
            ) : (
              <a
                href={crumb.href}
                class="hidden sm:inline ff-display"
                style="font-size: 15px; font-weight: 400; letter-spacing: -0.02em; color: var(--color-meta); text-decoration: none;"
              >{crumb.label.toLowerCase()}</a>
            )}
          </>
        );
      })}
    </div>

    <!-- Desktop nav links (hidden on mobile) -->
    <nav class="hidden sm:flex items-center gap-5 md:gap-6">
      {links.map(({ href, label }) => (
        <a
          href={href}
          target={href.startsWith('http') ? '_blank' : undefined}
          rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="ff-display"
          style={`font-size: 11px; font-weight: 500; letter-spacing: 0.08em; color: ${isActive(href, label) ? 'var(--color-ink)' : 'var(--color-meta)'}; text-decoration: none; border-bottom: ${isActive(href, label) ? '1px solid var(--color-ink)' : 'none'}; padding-bottom: ${isActive(href, label) ? '2px' : '0'}; transition: color 0.15s;`}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Hamburger button (mobile only, hidden on sm+) -->
    <button
      id="nav-hamburger"
      class="sm:hidden flex flex-col justify-center gap-[5px] w-8 h-8 p-1 bg-transparent border-0 cursor-pointer"
      aria-expanded="false"
      aria-controls="nav-drawer"
      aria-label="Open navigation"
    >
      <span class="block w-full h-px" style="background: var(--color-ink);"></span>
      <span class="block w-full h-px" style="background: var(--color-ink);"></span>
      <span class="block w-full h-px" style="background: var(--color-ink);"></span>
    </button>

  </div>
</header>
<script is:inline>
  (function () {
    var h = document.querySelector('header');
    if (h) document.documentElement.style.setProperty('--nav-h', h.offsetHeight + 'px');
  })();
</script>

<!-- Mobile drawer (full-screen overlay) -->
<div
  id="nav-drawer"
  class="hidden fixed inset-0 z-50 flex-col px-6 py-5"
  style="background: var(--color-bg);"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation"
>
  <!-- Drawer header: logo + close button -->
  <div class="flex items-center justify-between mb-16">
    <a href="/" class="logo" aria-label="pasqualo.to home">
      <span class="logo-mark" aria-hidden="true">
        <svg class="bracket bracket--tl" width="10" height="10" viewBox="0 0 14 14" fill="none">
          <path d="M 1 5 L 1 1 L 5 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
        </svg>
        <span class="wordmark">
          <span class="wordmark__name">pasqualo</span><span class="wordmark__tld">.to</span>
        </span>
        <svg class="bracket bracket--br" width="10" height="10" viewBox="0 0 14 14" fill="none">
          <path d="M 13 9 L 13 13 L 9 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
        </svg>
      </span>
    </a>
    <button
      id="nav-drawer-close"
      class="flex items-center justify-center w-8 h-8 bg-transparent border-0 cursor-pointer ff-display"
      style="font-size: 22px; line-height: 1; color: var(--color-ink);"
      aria-label="Close navigation"
    >×</button>
  </div>

  <!-- Drawer links: large serif, 32px -->
  <nav class="flex flex-col gap-8">
    {links.map(({ href, label }) => (
      <a
        href={href}
        target={href.startsWith('http') ? '_blank' : undefined}
        rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
        class="ff-serif"
        style={`font-size: 32px; font-weight: 400; letter-spacing: -0.02em; color: ${isActive(href, label) ? 'var(--color-ink)' : 'var(--color-ink-muted)'}; text-decoration: none;`}
      >
        {label}
      </a>
    ))}
  </nav>
</div>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const drawer = document.getElementById('nav-drawer');
  const closeBtn = document.getElementById('nav-drawer-close');

  function openDrawer() {
    drawer?.classList.remove('hidden');
    drawer?.classList.add('flex');
    hamburger?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer?.classList.add('hidden');
    drawer?.classList.remove('flex');
    hamburger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && hamburger?.getAttribute('aria-expanded') === 'true') closeDrawer();
  });
</script>

<style>
  .logo {
    display: inline-flex;
    text-decoration: none;
    color: var(--color-ink);
  }
  .logo-mark {
    display: inline-grid;
    grid-template-columns: auto 1fr auto;
    align-items: stretch;
    column-gap: 8px;
    padding: 4px 2px;
  }
  .bracket {
    color: var(--color-ink);
    align-self: stretch;
    height: auto;
  }
  .bracket--tl { align-self: start; }
  .bracket--br { align-self: end; }
  .wordmark {
    display: inline-flex;
    align-items: baseline;
    line-height: 1;
  }
  .wordmark__name {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-weight: 500;
    font-size: 15px;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .wordmark__tld {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 18px;
    letter-spacing: -0.04em;
    color: var(--color-accent);
    margin-left: 1px;
  }
</style>
