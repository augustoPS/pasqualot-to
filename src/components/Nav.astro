---
import { SITE_NAME, SHOW_NOTES } from '../config';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  breadcrumbs?: Crumb[];
}

const { breadcrumbs = [] } = Astro.props;

const links = [
  { href: '/', label: 'gallery' },
  ...(SHOW_NOTES ? [{ href: '/notes', label: 'notes' }] : []),
  { href: 'https://shop.pasqualo.to', label: 'shop' },
  { href: '/about', label: 'about' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string, label: string): boolean {
  if (label === 'gallery') return currentPath === '/' || currentPath.startsWith('/gallery');
  if (href.startsWith('http')) return false;
  return currentPath === href || (href !== '/' && currentPath.startsWith(href));
}

const hasBreadcrumbs = breadcrumbs.length > 0;
---

<header
  class="sticky top-0 z-40 border-b"
  style="border-color: var(--color-line); background-color: var(--color-bg);"
>
  <div class="flex items-baseline justify-between px-6 md:px-10 py-5">

    <!-- Logo with optional inline breadcrumb path -->
    <a
      href="/"
      style="font-family: var(--font-display); font-size: 15px; font-weight: 500; letter-spacing: -0.02em; color: var(--color-ink); text-decoration: none;"
    >
      {SITE_NAME}
      {hasBreadcrumbs && breadcrumbs.map((crumb, i) => {
        const isLast = i === breadcrumbs.length - 1;
        return (
          <>
            <span style="color: var(--color-dim); font-weight: 300; margin: 0 6px;">/</span>
            {isLast ? (
              <span>{crumb.label.toLowerCase()}</span>
            ) : (
              <a
                href={crumb.href}
                style="color: var(--color-meta); font-weight: 400; text-decoration: none;"
                onclick="event.stopPropagation()"
              >{crumb.label.toLowerCase()}</a>
            )}
          </>
        );
      })}
    </a>

    <!-- Nav links -->
    <nav class="flex items-center gap-5 md:gap-6">
      {links.map(({ href, label }) => (
        <a
          href={href}
          target={href.startsWith('http') ? '_blank' : undefined}
          rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
          style={`font-family: var(--font-display); font-size: 11px; font-weight: 500; letter-spacing: 0.08em; color: ${isActive(href, label) ? 'var(--color-ink)' : 'var(--color-meta)'}; text-decoration: none; border-bottom: ${isActive(href, label) ? '1px solid var(--color-ink)' : 'none'}; padding-bottom: ${isActive(href, label) ? '2px' : '0'}; transition: color 0.15s;`}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>
