---
import { SITE_NAME, SHOW_BLOG } from '../config';

const links = [
  { href: '/', label: 'Gallery' },
  ...(SHOW_BLOG ? [{ href: '/blog', label: 'Blog' }] : []),
  { href: '/notes', label: 'Notes' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<nav class="flex items-center justify-between px-6 py-5 border-b border-[var(--color-border)]">
  <a href="/" class="text-sm font-medium tracking-widest uppercase text-[var(--color-accent)] hover:opacity-70 transition-opacity">
    {SITE_NAME}
  </a>
  <ul class="flex gap-6">
    {links.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class:list={[
            'text-sm transition-colors',
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'text-[var(--color-accent)]'
              : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
          ]}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>
