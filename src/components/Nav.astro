---
import { SITE_NAME, SHOW_NOTES } from '../config';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  breadcrumbs?: Crumb[];
}

const { breadcrumbs = [] } = Astro.props;

const links = [
  { href: '/', label: 'gallery' },
  ...(SHOW_NOTES ? [{ href: '/notes', label: 'notes' }] : []),
  { href: 'https://shop.pasqualo.to', label: 'shop' },
  { href: '/about', label: 'about' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string, label: string): boolean {
  if (label === 'gallery') return currentPath === '/' || currentPath.startsWith('/gallery');
  if (href.startsWith('http')) return false;
  return currentPath === href || (href !== '/' && currentPath.startsWith(href));
}

const hasBreadcrumbs = breadcrumbs.length > 0;
---

<header
  class="sticky top-0 z-40 border-b"
  style="border-color: var(--color-line); background-color: var(--color-bg);"
>
  <!-- Top row: logo (left) + nav links (right) — same on all viewports -->
  <div class="flex items-center justify-between px-6 md:px-10 py-4">
    <!-- Logo -->
    <a
      href="/"
      style="font-family: var(--font-serif); font-size: 15px; font-weight: 400; color: var(--color-ink); text-decoration: none; letter-spacing: 0;"
    >
      {SITE_NAME}
    </a>

    <!-- Nav links — always inline, both mobile and desktop -->
    <nav class="flex items-center gap-5 md:gap-8">
      {links.map(({ href, label }) => (
        <a
          href={href}
          target={href.startsWith('http') ? '_blank' : undefined}
          rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
          style={`font-family: var(--font-mono); font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: ${isActive(href, label) ? 'var(--color-ink)' : 'var(--color-meta)'}; text-decoration: none; border-bottom: ${isActive(href, label) ? '1px solid var(--color-accent)' : 'none'}; padding-bottom: ${isActive(href, label) ? '2px' : '0'}; transition: color 0.15s;`}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>

  <!-- Breadcrumb row — only shown when breadcrumbs exist -->
  {hasBreadcrumbs && (
    <div
      class="flex items-center px-6 md:px-10 pb-3 gap-0"
    >
      <a
        href="/"
        style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-dim); text-decoration: none;"
      >{SITE_NAME}</a>
      {breadcrumbs.map((crumb, i) => {
        const isLast = i === breadcrumbs.length - 1;
        return (
          <>
            <span
              class="mx-2"
              style="font-family: var(--font-mono); font-size: 10px; color: var(--color-dim);"
            >/</span>
            {isLast ? (
              <span
                style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-ink);"
              >{crumb.label.toUpperCase()}</span>
            ) : (
              <a
                href={crumb.href}
                style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-dim); text-decoration: none;"
              >{crumb.label.toUpperCase()}</a>
            )}
          </>
        );
      })}
    </div>
  )}
</header>
