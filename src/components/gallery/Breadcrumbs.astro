---
interface Props {
  crumbs: { label: string; href: string }[];
}
const { crumbs } = Astro.props;
---
<nav class="text-xs text-[var(--color-muted)] mb-2 flex flex-wrap gap-1 items-center">
  {crumbs.map((crumb, i) => (
    <>
      {i > 0 && <span class="select-none" aria-hidden="true">/</span>}
      {i === crumbs.length - 1 ? (
        <span class="text-[var(--color-text)]">{crumb.label}</span>
      ) : (
        <a href={crumb.href} class="hover:text-[var(--color-text)] transition-colors">{crumb.label}</a>
      )}
    </>
  ))}
</nav>
