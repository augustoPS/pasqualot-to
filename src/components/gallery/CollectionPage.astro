---
import type { CollectionEntry } from 'astro:content';

interface ChildNode {
  id: string;
  title: string;
  href: string;
  coverSrc: string;
  meta: string;
  protected: boolean;
  isCollection: boolean;
}

interface Props {
  collection: CollectionEntry<'albumCollections'>;
  children: ChildNode[];
  hasAll: boolean;
}

const { collection, children } = Astro.props;
const { title, date, location, blurb } = collection.data;
const year = new Date(date).getFullYear();
const meta = location ? `${location} · ${year}` : String(year);
---

<!-- Series hero -->
<div
  class="flex flex-col md:flex-row gap-[72px] px-10 pt-16 pb-12 max-w-[1200px] mx-auto border-b"
  style="border-color: var(--color-line);"
>
  <div class="flex-1">
    <h1
      style="font-family: var(--font-serif); font-size: clamp(32px, 4vw, 56px); font-weight: 400; letter-spacing: -0.03em; line-height: 1.05; color: var(--color-ink);"
    >{title}</h1>
    <p
      class="mt-3"
      style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta);"
    >{meta}</p>
  </div>
  <div class="md:w-[280px] shrink-0 flex flex-col justify-end">
    {blurb && (
      <p
        style="font-family: var(--font-mono); font-size: 11px; line-height: 1.7; color: var(--color-meta);"
      >{blurb}</p>
    )}
    <p
      class="mt-3"
      style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-dim);"
    >{children.length} album{children.length !== 1 ? 's' : ''}</p>
  </div>
</div>

<!-- Album grid -->
<section class="px-10 py-16 max-w-[1200px] mx-auto">
  {children.length === 0 ? (
    <p style="color: var(--color-meta); font-size: 14px;">No albums yet.</p>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3" style="gap: 20px;">
      {children.map((child, i) => (
        <a href={child.href} class="group block" style="text-decoration: none;">
          <div class="relative overflow-hidden" style="aspect-ratio: 4/5;">
            <img
              src={child.coverSrc}
              alt={child.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
              loading="lazy"
            />
            {child.protected && (
              <div
                class="absolute bottom-0 left-0 px-2 py-1"
                style="background: rgba(0,0,0,0.6); font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta);"
              >
                🔒 Protected
              </div>
            )}
          </div>
          <div class="mt-3">
            <span
              class="block mb-1"
              style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; color: var(--color-dim);"
            >{String(i + 1).padStart(2, '0')}</span>
            <h2
              class="group-hover:text-[var(--color-accent)] transition-colors"
              style="font-family: var(--font-serif); font-size: 22px; font-weight: 400; letter-spacing: -0.02em; line-height: 1.1; color: var(--color-ink);"
            >{child.title}</h2>
            <p
              class="mt-1"
              style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta);"
            >{child.meta}</p>
          </div>
        </a>
      ))}
    </div>
  )}
</section>
