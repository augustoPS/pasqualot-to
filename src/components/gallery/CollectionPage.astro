---
import type { CollectionEntry } from 'astro:content';

interface ChildNode {
  id: string;
  title: string;
  href: string;
  coverSrc: string;
  meta: string;
  protected: boolean;
  isCollection: boolean;
}

interface Props {
  collection: CollectionEntry<'albumCollections'>;
  children: ChildNode[];
  hasAll: boolean;
}

const { collection, children } = Astro.props;
const { title, date, location, blurb } = collection.data;
const year = new Date(date).getFullYear();
const meta = location ? `${location} · ${year}` : String(year);
---

<!-- Series header -->
<div
  class="px-10 pt-10 pb-12 max-w-[1200px] mx-auto"
>
  <!-- Back link -->
  <a
    href="/"
    class="inline-block mb-10 ff-display"
    style="font-size: 10px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta); text-decoration: none;"
  >← ALL SERIES</a>

  <!-- Title + album count row -->
  <div class="flex items-start justify-between">
    <div>
      <h1
        class="ff-serif"
        style="font-size: clamp(56px, 8vw, 96px); font-weight: 400; letter-spacing: -0.04em; line-height: 1.0; color: var(--color-ink);"
      >{title}</h1>
      {blurb && (
        <p
          class="mt-4 ff-serif"
          style="font-size: 18px; font-style: italic; line-height: 1.5; color: var(--color-ink-muted);"
        >{blurb}</p>
      )}
    </div>
    <div
      class="shrink-0 ml-8 text-right ff-mono"
      style="font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-dim); padding-top: 8px;"
    >
      <span style="display: block; font-size: 18px; color: var(--color-ink-muted); letter-spacing: 0; font-style: normal;">{children.length}</span>
      ALBUMS
    </div>
  </div>
</div>

<!-- Hairline -->
<div style="border-top: 1px solid var(--color-line);"></div>

<!-- Album grid -->
<section class="px-10 py-16 max-w-[1200px] mx-auto">
  {children.length === 0 ? (
    <p class="ff-serif" style="color: var(--color-meta); font-size: 14px;">No albums yet.</p>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3" style="gap: 20px;">
      {children.map((child, i) => (
        <a href={child.href} class="group block" style="text-decoration: none;">
          <div class="relative overflow-hidden" style="aspect-ratio: 4/5;">
            <img
              src={child.coverSrc}
              alt={child.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
              loading="lazy"
            />
            {child.protected && (
              <div
                class="absolute bottom-0 left-0 px-2 py-1 ff-mono"
                style="background: rgba(0,0,0,0.6); font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta);"
              >
                🔒 Protected
              </div>
            )}
          </div>
          <div class="mt-3">
            <span
              class="block mb-1 ff-mono"
              style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-dim);"
            >{String(i + 1).padStart(2, '0')}</span>
            <h2
              class="group-hover:text-[var(--color-accent)] transition-colors ff-serif"
              style="font-size: 22px; font-weight: 400; letter-spacing: -0.02em; line-height: 1.1; color: var(--color-ink);"
            >{child.title}</h2>
            <p
              class="mt-1 ff-mono"
              style="font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta);"
            >{child.meta}</p>
          </div>
        </a>
      ))}
    </div>
  )}
</section>
