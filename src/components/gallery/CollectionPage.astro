---
import type { CollectionEntry } from 'astro:content';
import Breadcrumbs from './Breadcrumbs.astro';

interface ChildNode {
  id: string;
  title: string;
  href: string;
  coverSrc: string;
  meta: string;
  protected: boolean;
  isCollection: boolean;
}

interface Props {
  collection: CollectionEntry<'albumCollections'>;
  children: ChildNode[];
  breadcrumbs: { label: string; href: string }[];
  hasAll: boolean;
}

const { collection, children, breadcrumbs, hasAll } = Astro.props;
const { title, date, location, description } = collection.data;
const year = new Date(date).getFullYear();
---

<div class="max-w-5xl mx-auto px-6 py-8">
  <Breadcrumbs crumbs={breadcrumbs} />
  <h1 class="text-2xl font-medium text-[var(--color-accent)]">{title}</h1>
  <p class="text-sm text-[var(--color-muted)] mt-1">
    {location ? `${location}, ` : ''}{year}
  </p>
  {description && (
    <p class="text-sm text-[var(--color-text)] mt-2 max-w-xl">{description}</p>
  )}

  {hasAll && (
    <div class="mt-6 mb-2">
      <a
        href={`/gallery/${collection.id}/all`}
        class="inline-block text-xs text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors border border-[var(--color-border)] px-3 py-1.5"
      >
        All photos
      </a>
    </div>
  )}

  {children.length === 0 ? (
    <p class="text-[var(--color-muted)] text-sm mt-8">No albums yet.</p>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 mt-6">
      {children.map((child) => (
        <a href={child.href} class="group block overflow-hidden bg-[var(--color-surface)]">
          <div class="aspect-[4/3] overflow-hidden relative">
            <img
              src={child.coverSrc}
              alt={child.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            {child.protected && (
              <span class="absolute bottom-2 left-2 text-[var(--color-muted)]">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                </svg>
                <span class="sr-only">Protected album</span>
              </span>
            )}
            {child.isCollection && (
              <span class="absolute bottom-2 right-2 text-[var(--color-muted)] text-xs bg-black/50 px-1.5 py-0.5">
                collection
              </span>
            )}
          </div>
          <div class="px-3 py-3">
            <p class="text-sm font-medium text-[var(--color-text)]">{child.title}</p>
            <p class="text-xs text-[var(--color-muted)] mt-0.5">{child.meta}</p>
          </div>
        </a>
      ))}
    </div>
  )}
</div>
