---
import type { CollectionEntry } from 'astro:content';
import { cdnUrl, cdnThumbUrl, apiUrl, apiThumbUrl } from '../../lib/photos';

interface Props {
  album: CollectionEntry<'albums'>;
  prevAlbum?: CollectionEntry<'albums'>;
  nextAlbum?: CollectionEntry<'albums'>;
  collection?: CollectionEntry<'albumCollections'>;
  albumPosition?: number;
  albumTotal?: number;
}

const { album, prevAlbum, nextAlbum, collection, albumPosition, albumTotal } = Astro.props;
const { title, date, location, photos, previewCount, description } = album.data;
const isProtected = album.data.protected;
const dateObj = new Date(date);
const monthYear = dateObj.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }).toUpperCase();
const metaParts = [
  location ? location.toUpperCase() : null,
  monthYear,
  `${photos.length} FRAMES`,
].filter(Boolean).join(' · ');

const previewPhotos = isProtected ? photos.slice(0, previewCount) : photos;
const lockedCount = isProtected ? Math.max(0, photos.length - previewCount) : 0;
const previewFiles = new Set(previewPhotos.map((p) => p.file));

function thumbUrl(file: string) {
  if (!isProtected || previewFiles.has(file)) return cdnThumbUrl(album.id, file);
  return apiThumbUrl(album.id, file);
}
function fullUrl(file: string) {
  if (!isProtected || previewFiles.has(file)) return cdnUrl(album.id, file);
  return apiUrl(album.id, file);
}
---

<div class="px-10 py-16 max-w-[1200px] mx-auto">

  <!-- Album header -->
  <header class="mb-14 text-center">
    {(collection || (albumPosition && albumTotal)) && (
      <p
        class="mb-4 ff-mono"
        style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);"
      >
        {collection?.data.title}
        {albumPosition && albumTotal && (
          <span style="color: var(--color-dim);"> · </span>
        )}
        {albumPosition && albumTotal && `${albumPosition} OF ${albumTotal}`}
      </p>
    )}
    <h1
      class="ff-serif"
      style="font-size: clamp(48px, 7vw, 72px); font-weight: 300; font-style: normal; letter-spacing: -0.02em; line-height: 1.0; color: var(--color-ink);"
    >{title}.</h1>
    <p
      class="mt-5 ff-mono"
      style="font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta);"
    >{metaParts}</p>
    {description && (
      <p
        class="mt-5 mx-auto max-w-xl ff-serif"
        style="font-size: 18px; font-weight: 400; line-height: 1.6; color: var(--color-ink-muted);"
      >{description}</p>
    )}
  </header>

  <!-- Preview photos (always shown for protected albums) -->
  {isProtected && previewPhotos.length > 0 && (
    <div
      id="photo-grid-preview"
      class="columns-2 md:columns-3 mb-14"
      style="column-gap: 5px;"
    >
      {previewPhotos.map((photo, i) => (
        <button
          class="gallery-photo block w-full p-0 border-0 bg-transparent mb-[5px] break-inside-avoid cursor-zoom-in"
          data-src={fullUrl(photo.file)}
          data-alt={photo.alt}
          data-index={i}
          data-lens={photo.lens ?? ''}
          data-caption={photo.title ?? ''}
          aria-label={`View ${photo.alt}`}
        >
          <img
            src={thumbUrl(photo.file)}
            alt={photo.alt}
            class="w-full h-auto block"
            loading={i < 6 ? 'eager' : 'lazy'}
          />
          <span
            class="block mt-1 mb-3 ff-mono"
            style="font-size: 9px; letter-spacing: 0.12em; color: var(--color-dim);"
          >{String(i + 1).padStart(3, '0')}</span>
        </button>
      ))}
    </div>
  )}

  <!-- Password gate — shown when protected and locked photos remain -->
  {isProtected && lockedCount > 0 && (
    <div
      id="password-gate"
      class="py-16 flex flex-col items-center text-center border-t border-b mb-14"
      style="border-color: var(--color-line);"
    >
      <p
        class="mb-2 ff-serif"
        style="font-size: 19px; font-style: italic; color: var(--color-ink-muted);"
      >This album is protected.</p>
      <p
        class="mb-8 ff-mono"
        style="font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta);"
      >{lockedCount} more frame{lockedCount !== 1 ? 's' : ''} locked</p>

      <form id="password-form" class="flex flex-col sm:flex-row gap-3 w-full max-w-sm">
        <input
          type="password"
          id="password-input"
          placeholder="password"
          aria-label="Album password"
          class="flex-1 px-4 py-2 text-sm outline-none"
          style="background: var(--color-surface); border: 1px solid var(--color-line-2); color: var(--color-ink); letter-spacing: 0.08em;"
          autocomplete="current-password"
        />
        <button
          id="unlock-btn"
          type="submit"
          class="px-6 py-2 transition-opacity disabled:opacity-40 ff-display"
          style="background: var(--color-ink); color: var(--color-bg); font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; border: none; cursor: pointer;"
        >
          Unlock
        </button>
      </form>
      <p
        id="password-error"
        role="alert"
        class="mt-4 hidden ff-mono"
        style="font-size: 10px; letter-spacing: 0.12em; color: #c0392b;"
      >Incorrect password.</p>
    </div>
  )}

  <!-- Full photo grid (unlocked / public albums) -->
  {!isProtected && (
    <div
      id="photo-grid"
      class="columns-2 md:columns-3 mb-14"
      style="column-gap: 5px;"
    >
      {photos.map((photo, i) => (
        <button
          class="gallery-photo block w-full p-0 border-0 bg-transparent mb-[5px] break-inside-avoid cursor-zoom-in"
          data-src={fullUrl(photo.file)}
          data-alt={photo.alt}
          data-index={i}
          data-lens={photo.lens ?? ''}
          data-caption={photo.title ?? ''}
          aria-label={`View ${photo.alt}`}
        >
          <img
            src={thumbUrl(photo.file)}
            alt={photo.alt}
            class="w-full h-auto block"
            loading={i < 6 ? 'eager' : 'lazy'}
          />
          <span
            class="block mt-1 mb-3 ff-mono"
            style="font-size: 9px; letter-spacing: 0.12em; color: var(--color-dim);"
          >{String(i + 1).padStart(3, '0')}</span>
        </button>
      ))}
    </div>
  )}

  <!-- Prev / next footer -->
  <footer
    class="pt-8 border-t grid grid-cols-3 text-center"
    style="border-color: var(--color-line);"
  >
    <div class="text-left">
      {prevAlbum && (
        <a
          href={`/gallery/${prevAlbum.id}`}
          class="ff-mono"
          style="font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-meta); text-decoration: none;"
        >← {prevAlbum.data.title}</a>
      )}
    </div>
    <div></div>
    <div class="text-right">
      {nextAlbum ? (
        <a
          href={`/gallery/${nextAlbum.id}`}
          class="ff-mono"
          style="font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-meta); text-decoration: none;"
        >{nextAlbum.data.title} →</a>
      ) : (
        <span
          class="ff-serif"
          style="font-size: 12px; font-style: italic; color: var(--color-dim);"
        >end of series</span>
      )}
    </div>
  </footer>

</div>

<!-- Album config for lightbox script -->
<div
  id="album-config"
  data-album-id={album.id}
  data-is-protected={String(isProtected)}
  data-preview-count={String(previewCount ?? 0)}
  hidden
></div>

<!-- Lightbox markup -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Photo lightbox"
  style="background: rgba(10,10,10,0.96);"
>
  <button
    id="lightbox-close"
    class="absolute top-5 right-6 z-10"
    aria-label="Close lightbox"
    style="font-size: 20px; color: var(--color-meta); background: none; border: none; cursor: pointer; line-height: 1; padding: 10px;"
  >×</button>

  <button
    id="lightbox-prev"
    class="absolute left-4 top-1/2 -translate-y-1/2 z-10"
    aria-label="Previous photo"
    style="font-size: 28px; color: rgba(182,178,168,0.4); background: none; border: none; cursor: pointer; padding: 20px 16px; transition: color 0.15s;"
  >‹</button>

  <button
    id="lightbox-next"
    class="absolute right-4 top-1/2 -translate-y-1/2 z-10"
    aria-label="Next photo"
    style="font-size: 28px; color: rgba(182,178,168,0.4); background: none; border: none; cursor: pointer; padding: 20px 16px; transition: color 0.15s;"
  >›</button>

  <div id="lightbox-stage" class="absolute inset-0 flex items-center justify-center">
    <img
      id="lightbox-img"
      src=""
      alt=""
      style="max-width: min(92vw, 1600px); max-height: 88vh; object-fit: contain; will-change: transform; transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1), opacity 280ms ease;"
    />
  </div>

  <div
    id="lightbox-meta"
    class="absolute bottom-5 left-6 ff-mono"
    style="font-size: 10px; letter-spacing: 0.12em; color: var(--color-meta);"
  >
    <span id="lightbox-frame"></span>
    <span id="lightbox-lens" class="ml-4"></span>
  </div>
</div>

<script src="/scripts/gallery.js" defer></script>
