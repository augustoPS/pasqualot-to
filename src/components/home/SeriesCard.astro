---
interface Props {
  index: number;
  title: string;
  href: string;
  coverSrc: string;
  meta: string;
  albumCount: number;
  stackThumbs: { src: string; alt: string }[];
}

const { index, title, href, coverSrc, meta, albumCount } = Astro.props;
const indexLabel = String(index).padStart(2, '0');
const metaLine = albumCount > 1 ? `${meta} · ${albumCount} albums` : meta;
---

<a
  href={href}
  class="group block"
  style="text-decoration: none;"
>
  <div class="relative overflow-hidden" style="aspect-ratio: 4/5; width: 100%;">
    <img
      src={coverSrc}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
      loading="lazy"
    />

    <!-- Index overlay - top left -->
    <div
      class="absolute top-0 left-0 p-3 ff-mono"
      style="font-size: 10px; letter-spacing: 0.14em; color: var(--color-dim); text-shadow: 0 1px 3px rgba(0,0,0,0.5);"
    >{indexLabel}</div>

    <!-- Title and meta overlay - bottom -->
    <div
      class="absolute bottom-0 left-0 right-0 ff-serif"
      style="background: linear-gradient(to top, rgba(10,10,10,1) 0%, rgba(10,10,10,0.85) 60%, transparent 100%); padding: 2rem 1rem 1rem 1rem;"
    >
      <h2
        class="group-hover:text-[var(--color-accent)] transition-colors"
        style="font-size: 22px; font-weight: 400; letter-spacing: -0.02em; line-height: 1.2; color: var(--color-ink); margin: 0;"
      >{title}</h2>
      <p
        class="mt-2 ff-mono"
        style="font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta); margin: 0;"
      >{metaLine}</p>
    </div>
  </div>
</a>
