---
interface StackThumb {
  src: string;
  alt: string;
}

interface Props {
  index: number;
  title: string;
  href: string;
  coverSrc: string;
  meta: string;
  albumCount: number;
  stackThumbs: StackThumb[];
}

const { index, title, href, coverSrc, meta, albumCount, stackThumbs } = Astro.props;
const indexLabel = String(index).padStart(2, '0');
---

<a
  href={href}
  class="group block"
  style="text-decoration: none;"
>
  <!-- Cover -->
  <div class="relative overflow-hidden" style="aspect-ratio: 4/5; width: 100%;">
    <img
      src={coverSrc}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
      loading="lazy"
    />

    <!-- Album count overlay - bottom right -->
    {albumCount > 1 && (
      <div
        class="absolute bottom-3 right-3 px-2 py-1 ff-mono"
        style="background: rgba(0,0,0,0.7); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-meta);"
      >{albumCount} albums</div>
    )}
  </div>

  <!-- Metadata below cover -->
  <div class="mt-3" style="padding-right: 1rem;">
    <div class="flex items-baseline gap-2">
      <span
        class="ff-mono"
        style="font-size: 8px; letter-spacing: 0.14em; color: var(--color-dim); flex-shrink: 0;"
      >{indexLabel}</span>
      <h2
        class="group-hover:text-[var(--color-accent)] transition-colors ff-serif"
        style="font-size: 22px; font-weight: 400; letter-spacing: -0.02em; line-height: 1.1; color: var(--color-ink); margin: 0;"
      >{title}</h2>
    </div>
    <p
      class="mt-2 ff-mono"
      style="font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta); margin: 0;"
    >
      {meta}
    </p>
  </div>
</a>
