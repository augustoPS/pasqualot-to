---
interface StackThumb {
  src: string;
  alt: string;
}

interface Props {
  index: number;
  title: string;
  href: string;
  coverSrc: string;
  meta: string;
  albumCount: number;
  stackThumbs: StackThumb[];
}

const { index, title, href, coverSrc, meta, albumCount, stackThumbs } = Astro.props;
const indexLabel = String(index).padStart(2, '0');
---

<a
  href={href}
  class="group block"
  style="text-decoration: none;"
>
  <!-- Cover with 4:5 aspect ratio -->
  <div class="relative overflow-hidden" style="aspect-ratio: 4/5;">
    <img
      src={coverSrc}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
      loading="lazy"
    />

    <!-- Stack indicator (multi-album only) -->
    {stackThumbs.length > 1 && (
      <div class="absolute bottom-3 right-3" style="width: 60px; height: 60px;">
        {stackThumbs.slice(0, 3).map((thumb, i) => (
          <img
            src={thumb.src}
            alt=""
            aria-hidden="true"
            class="absolute"
            style={`width: 36px; height: 45px; object-fit: cover; bottom: 0; right: ${i * 10}px; outline: 1px solid var(--color-bg); opacity: ${1 - i * 0.25};`}
          />
        ))}
      </div>
    )}
  </div>

  <!-- Card meta below image -->
  <div class="mt-3">
    <div class="flex items-baseline justify-between mb-1">
      <span
        class="ff-mono"
        style="font-size: 10px; font-weight: 400; letter-spacing: 0.14em; color: var(--color-dim);"
      >{indexLabel}</span>
      {albumCount > 1 && (
        <span
          class="ff-mono"
          style="font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-dim);"
        >{albumCount} albums</span>
      )}
    </div>
    <h2
      class="group-hover:text-[var(--color-accent)] transition-colors ff-serif"
      style="font-size: 26px; font-weight: 400; letter-spacing: -0.03em; line-height: 1.1; color: var(--color-ink);"
    >
      {title}
    </h2>
    <p
      class="mt-1 ff-mono"
      style="font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta);"
    >
      {meta}
    </p>
  </div>
</a>
