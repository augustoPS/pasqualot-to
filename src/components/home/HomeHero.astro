---
import { getCollection } from 'astro:content';
import { cdnUrl } from '../../lib/photos';

const allAlbums = await getCollection('albums');
const allCollections = await getCollection('albumCollections');
const publicAlbums = allAlbums.filter((a) => !a.data.protected && a.data.photos.length > 0);

const childIds = new Set(allCollections.flatMap((c) => c.data.children));
const seriesCount = allCollections.filter((c) => !childIds.has(c.id) && !c.data.hidden).length;
const albumCount = allAlbums.length;

let coverSrc: string | undefined;
let coverAlbumHref = '/series';
let orientation: 'portrait' | 'landscape' = 'portrait';
let coverFocal: string | undefined;
let coverBg: string | undefined;

if (publicAlbums.length > 0) {
  const album = publicAlbums[Math.floor(Math.random() * publicAlbums.length)];
  coverSrc = cdnUrl(album.id, album.data.cover);
  coverAlbumHref = `/series/${album.id}`;
  orientation = album.data.coverOrientation ?? 'portrait';
  coverFocal = album.data.coverFocal;
  coverBg = album.data.coverBg;
}

const isLandscape = orientation === 'landscape';
const objectPosition = coverFocal ?? (isLandscape ? 'center' : 'center 25%');
---

<section class="flex items-stretch" style="height: calc(100vh - var(--nav-h));">

  <!-- Left: tagline + bio + stat -->
  <div class="flex flex-col justify-end px-10 py-16 flex-1">
    <h1
      class="ff-serif"
      style="font-size: clamp(64px, 7.5vw, 96px); font-weight: 300; letter-spacing: -0.04em; line-height: 1.0; color: var(--color-ink);"
    >
      「Quietly,<br /><em style="font-style: italic; font-weight: 300; color: var(--color-accent);">between takes.」</em>
    </h1>
    <p
      class="mt-3 mb-6 ff-mono"
      style="font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);"
    >ONGOING ARCHIVE</p>
    <p
      class="ff-serif"
      style="font-size: 19px; font-weight: 400; line-height: 1.6; color: var(--color-ink-muted); max-width: 420px;"
    >
      A small archive of photographs made in Porto Alegre
      and elsewhere, mostly between other things.
    </p>
    <a
      href="/series"
      class="mt-8 ff-mono"
      style="font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-meta); text-decoration: none; display: inline-block;"
    >{seriesCount} SERIES · {albumCount} ALBUMS →</a>
  </div>

  <!-- Right: cover photo — width adapts to orientation -->
  {coverSrc && (
    <a
      href={coverAlbumHref}
      class={`hidden md:block relative overflow-hidden shrink-0 ${isLandscape ? 'md:w-[60%]' : 'md:w-[45%]'}`}
      style={`text-decoration: none;${coverBg ? ` background-color: ${coverBg};` : ''}`}
    >
      <img
        src={coverSrc}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover"
        style={`object-position: ${objectPosition};`}
        loading="eager"
        fetchpriority="high"
      />
    </a>
  )}

</section>
