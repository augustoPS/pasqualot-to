---
interface Props {
  featuredCoverSrc?: string;
  featuredHref?: string;
}

const { featuredCoverSrc, featuredHref } = Astro.props;
---

<section class="flex flex-col md:flex-row min-h-[80vh]">
  <!-- Left: kicker + tagline + bio -->
  <div class="flex flex-col justify-end px-10 pb-16 pt-24 flex-1">
    <p
      class="mb-6"
      style="font-family: var(--font-mono); font-size: 10px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-meta);"
    >
      PASQUALO.TO · 2025–26
    </p>
    <h1
      style="font-family: var(--font-serif); font-size: clamp(36px, 4vw, 48px); font-weight: 300; letter-spacing: -0.015em; line-height: 1.05; color: var(--color-ink);"
    >
      Quietly,<br /><em style="font-style: italic; font-weight: 300; color: var(--color-ink-muted);">between takes.</em>
    </h1>
    <p
      class="mt-5 max-w-xs"
      style="font-family: var(--font-serif); font-size: 15px; font-weight: 300; line-height: 1.65; color: var(--color-ink-muted);"
    >
      A small archive of photographs made in Porto Alegre
      and elsewhere, mostly between other things.
    </p>
  </div>

  <!-- Right: featured cover photo -->
  {featuredCoverSrc && (
    <a
      href={featuredHref ?? '/'}
      class="hidden md:flex md:w-[24%] shrink-0 items-end pb-16 pr-10"
      style="text-decoration: none;"
    >
      <div class="w-full" style="aspect-ratio: 4/5; max-height: 28vh;">
        <img
          src={featuredCoverSrc}
          alt=""
          aria-hidden="true"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    </a>
  )}
</section>
